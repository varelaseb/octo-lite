#!/usr/bin/env bash
set -euo pipefail

workspace=""
name=""
label=""
cwd="$PWD"
role=""
receipt=""
while (($#)); do
  case "$1" in
    --workspace) workspace="${2:?}"; shift 2 ;;
    --name) name="${2:?}"; shift 2 ;;
    --label) label="${2:?}"; shift 2 ;;
    --cwd) cwd="${2:?}"; shift 2 ;;
    --role) role="${2:?}"; shift 2 ;;
    --receipt) receipt="${2:?}"; shift 2 ;;
    --) shift; break ;;
    *) echo "herdr-spawn: unknown option $1" >&2; exit 64 ;;
  esac
done
[[ -n "$workspace" && -n "$name" && -n "$role" && $# -gt 0 ]] || exit 64
[[ -d "$cwd" ]] || exit 66
cwd="$(cd "$cwd" && pwd -P)"
[[ -z "$receipt" || -f "$receipt" ]] || exit 66

value_after() {
  local wanted="$1" previous=""
  shift
  for value in "$@"; do
    [[ "$previous" == "$wanted" ]] && { echo "$value"; return 0; }
    previous="$value"
  done
  return 1
}

[[ "$1" == claude ]] || { echo "herdr-spawn: persistent tabs require Claude" >&2; exit 65; }
model="$(value_after --model "$@" || true)"
effort="$(value_after --effort "$@" || true)"
mode="$(value_after --permission-mode "$@" || true)"
agent="$(value_after --agent "$@" || true)"
case "$role" in
  meta-operator)
    [[ "$model" == claude-fable-5 && "$effort" == xhigh && "$mode" == auto && "$agent" == meta-operator ]] || exit 65
    [[ "$label" == "🧠 operator" ]] || exit 65
    ;;
  orchestrator|issue-shaper)
    [[ "$model" == 'claude-opus-4-8[1m]' && "$effort" == high && "$mode" == auto && "$agent" == "$role" ]] || exit 65
    grep -Eq '^(🎤 )?(◆)?[0-9]+(/[0-9]+)? · .+$' <<<"$label" || exit 65
    ;;
  *) echo "herdr-spawn: role has no persistent tab" >&2; exit 65 ;;
esac

out="$(herdr tab create --workspace "$workspace" --label "$label" --cwd "$cwd" --no-focus)"
tab="$(jq -r '.result.tab.tab_id // empty' <<<"$out")"
root_pane="$(jq -r '.result.root_pane.pane_id // empty' <<<"$out")"
[[ -n "$tab" ]] || exit 1

herdr agent start "$name" --tab "$tab" --cwd "$cwd" --no-focus -- "$@" >/dev/null
[[ -z "$root_pane" ]] || herdr pane close "$root_pane" >/dev/null 2>&1

pane=""
for _ in $(seq 1 10); do
  pane="$(herdr agent get "$name" 2>/dev/null | jq -r '.result.agent.pane_id // empty')"
  [[ -n "$pane" ]] && break
  sleep 1
done
[[ -n "$pane" ]] || exit 1

startup="pending"
for _ in $(seq 1 30); do
  text="$(herdr pane read "$pane" --source visible --lines 50 2>/dev/null)"
  if grep -qiE 'Quick safety check|trust this folder' <<<"$text"; then
    herdr pane run "$pane" "" >/dev/null 2>&1
    sleep 1
    continue
  fi
  if grep -q 'BOOTSTRAP_ACK' <<<"$text" && grep -Fq "$name" <<<"$text"; then
    startup="acknowledged"
    break
  fi
  sleep 2
done

echo "name=$name role=$role tab=$tab pane=$pane cwd=$cwd model=$model effort=$effort mode=$mode bootstrap=$startup receipt=${receipt:-none}"
[[ "$startup" == acknowledged ]] || exit 2
