#!/usr/bin/env bash
set -euo pipefail

kind="info"
artifact=""
while (($#)); do
  case "$1" in
    --kind) kind="${2:?}"; shift 2 ;;
    --artifact) artifact="${2:?}"; shift 2 ;;
    --) shift; break ;;
    -*) echo "herdr-say: unknown option $1" >&2; exit 64 ;;
    *) break ;;
  esac
done

target="${1:-}"
shift || true
message="$*"
case "$kind" in info|command|ruling|ownership|question) ;; *) exit 64 ;; esac
[[ -n "$target" && -n "$message" ]] || {
  echo "usage: herdr-say [--kind KIND] [--artifact REF] TARGET MESSAGE" >&2
  exit 64
}

root="${XDG_STATE_HOME:-$HOME/.local/state}/octo-lite/messages"
inbox="${XDG_STATE_HOME:-$HOME/.local/state}/octo-lite/inbox/$target"
mkdir -p "$root" "$inbox"
id="$(date -u +%Y%m%dT%H%M%S)-$$-$RANDOM"
state="$root/$id.toml"

quote() { jq -Rn --arg value "$1" '$value'; }

# Source B operator-gate stamp (sweep-operator-ask): when the lane operator-ask
# path sends a --kind question and OCTO_STREAM names the sending stream, stamp a
# mechanical per-stream operator-wait the sweep reads. This is written before any
# transport so it holds even when the pane is unresolved, and is modal-safe (no
# pane transcript scrape). The operator answer relay (herdr-ack of this exact
# message) clears it.
if [[ "$kind" == "question" && -n "${OCTO_STREAM:-}" ]]; then
  waits="${XDG_STATE_HOME:-$HOME/.local/state}/octo-lite/operator-waits"
  mkdir -p "$waits"
  wait_stamp="$waits/$OCTO_STREAM.toml"
  wait_tmp="$wait_stamp.$$.tmp"
  {
    echo 'schema_version = 1'
    echo "owner = $(quote "operator")"
    echo "stream = $(quote "$OCTO_STREAM")"
    echo "message_id = $(quote "$id")"
    echo "target = $(quote "$target")"
    echo "ask = $(quote "$message")"
    echo "created_at = $(quote "$(date -u +%Y-%m-%dT%H:%M:%SZ)")"
  } >"$wait_tmp"
  mv "$wait_tmp" "$wait_stamp"
fi

write_state() {
  local status="$1" temporary="$state.$$.tmp"
  {
    echo 'schema_version = 1'
    echo "message_id = $(quote "$id")"
    echo "target = $(quote "$target")"
    echo "kind = $(quote "$kind")"
    echo "status = $(quote "$status")"
    echo "artifact = $(quote "$artifact")"
    echo "message = $(quote "$message")"
    echo "created_at = $(quote "$(date -u +%Y-%m-%dT%H:%M:%SZ)")"
  } >"$temporary"
  mv "$temporary" "$state"
}

case "$target" in
  *:p*) pane="$target" ;;
  *)
    # TUR-447: a NON-ZERO `herdr agent get` (a hard error, not an empty pane)
    # must not abort herdr-say under set -euo pipefail before the write_state
    # pending guard below, or the pre-transport operator-wait stamp is orphaned.
    # Capture resolution tolerantly so BOTH an empty AND an errored resolution
    # fall through to the unresolved-target pending path.
    pane=""
    resolved="$(herdr agent get "$target" 2>/dev/null || true)"
    pane="$(printf '%s' "$resolved" | jq -r '.result.agent.pane_id // empty' 2>/dev/null || true)"
    ;;
esac
# TUR-447: an unresolved target aborts before any transport. The pending
# message-state guard exists ONLY to make a stamped operator-wait clearable.
# D5: scope it to the operator-wait kinds (--kind question with OCTO_STREAM,
# the exact case that just wrote the pre-transport operator-wait stamp keyed to
# this message id). For that case persist a pending message-state record so
# herdr-ack of this exact id can acknowledge and clear the wait via its
# advertised path; without it the wait is orphaned and unacknowledgeable.
# Status is pending, matching the ack lifecycle (pending -> acknowledged); no
# transport is claimed. For every NON-operator-wait message (no wait was
# stamped) writing a pending state would be falsely herdr-ack-acknowledgeable
# and would not retry; instead leave no state and exit 66 so the send stays
# retryable (herdr-drain retries transport once the target resolves).
[[ -n "$pane" ]] || {
  if [[ "$kind" == "question" && -n "${OCTO_STREAM:-}" ]]; then
    write_state pending
  fi
  echo "herdr-say: unresolved target $target" >&2
  exit 66
}

# herdr-say never infers composer state, consumption, or delivery from pane
# transcript text. This read only detects a modal or question dialog, so it
# never injects text or Enter into one; it never checks for the sent text itself.
dialog_open() {
  herdr pane read "$pane" --source visible --lines 40 2>/dev/null \
    | grep -qE 'Do you want|Do you trust|Quick safety check|trust this folder|Enter to confirm|to select|esc to cancel|❯ [0-9]+\.|❯ Yes|❯ No|\(y/n\)'
}

suffix=""
if [[ "$kind" != "info" ]]; then
  suffix=" [msg:$id kind:$kind] Acknowledge with: herdr-ack $id acknowledged --by $target"
fi

queue_and_exit() {
  write_state queued
  printf '%s\n' "$id" >"$inbox/$id"
  echo "herdr-say: queued message_id=$id" >&2
  exit 75
}

# A send or Enter transport attempt leaves the message pending, never re-pasted
# on retry. Only an explicit herdr-ack from the recipient proves delivery.
pending_deferred_exit() {
  write_state pending
  printf '%s\n' "$id" >"$inbox/$id"
  echo "herdr-say: transport attempted, delivery pending message_id=$id" >&2
  exit 75
}

if dialog_open; then
  queue_and_exit
fi

if herdr agent send "$target" "$message$suffix" >/dev/null 2>&1 \
  || herdr agent send "$pane" "$message$suffix" >/dev/null 2>&1; then
  sleep 0.5
  if dialog_open; then
    pending_deferred_exit
  fi
  if herdr pane run "$pane" "" >/dev/null 2>&1; then
    write_state pending
    echo "message_id=$id status=pending"
  else
    pending_deferred_exit
  fi
else
  queue_and_exit
fi
