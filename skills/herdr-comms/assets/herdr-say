#!/usr/bin/env bash
set -euo pipefail

kind="info"
artifact=""
while (($#)); do
  case "$1" in
    --kind) kind="${2:?}"; shift 2 ;;
    --artifact) artifact="${2:?}"; shift 2 ;;
    --) shift; break ;;
    -*) echo "herdr-say: unknown option $1" >&2; exit 64 ;;
    *) break ;;
  esac
done

target="${1:-}"
shift || true
message="$*"
case "$kind" in info|command|ruling|ownership|question) ;; *) exit 64 ;; esac
[[ -n "$target" && -n "$message" ]] || {
  echo "usage: herdr-say [--kind KIND] [--artifact REF] TARGET MESSAGE" >&2
  exit 64
}

case "$target" in
  *:p*) pane="$target" ;;
  *) pane="$(herdr agent get "$target" 2>/dev/null | jq -r '.result.agent.pane_id // empty')" ;;
esac
[[ -n "$pane" ]] || { echo "herdr-say: unresolved target $target" >&2; exit 66; }

root="${XDG_STATE_HOME:-$HOME/.local/state}/octo-lite/messages"
inbox="${XDG_STATE_HOME:-$HOME/.local/state}/octo-lite/inbox/$target"
mkdir -p "$root" "$inbox"
id="$(date -u +%Y%m%dT%H%M%S)-$$-$RANDOM"
state="$root/$id.toml"

quote() { jq -Rn --arg value "$1" '$value'; }
write_state() {
  local status="$1" temporary="$state.$$.tmp"
  {
    echo 'schema_version = 1'
    echo "message_id = $(quote "$id")"
    echo "target = $(quote "$target")"
    echo "kind = $(quote "$kind")"
    echo "status = $(quote "$status")"
    echo "artifact = $(quote "$artifact")"
    echo "message = $(quote "$message")"
    echo "created_at = $(quote "$(date -u +%Y-%m-%dT%H:%M:%SZ)")"
  } >"$temporary"
  mv "$temporary" "$state"
}

dialog_open() {
  herdr pane read "$pane" --source visible --lines 40 2>/dev/null \
    | grep -qE 'Do you want|Do you trust|Quick safety check|trust this folder|Enter to confirm|to select|esc to cancel|❯ [0-9]+\.|❯ Yes|❯ No|\(y/n\)'
}

# `pane run` can exit 0 (Enter was sent) while the exact text is still sitting
# unsubmitted in the composer. Only a read that proves the text is gone counts
# as consumption; an unreadable pane is ambiguous, never a submitted proof.
composer_cleared() {
  local text="$1" observed
  observed="$(herdr pane read "$pane" --source visible --lines 6 2>/dev/null)" || return 1
  [[ "$observed" != *"$text"* ]]
}

suffix=""
if [[ "$kind" != "info" ]]; then
  suffix=" [msg:$id kind:$kind] Acknowledge with: herdr-ack $id acknowledged --by $target"
fi

queue_and_exit() {
  write_state queued
  printf '%s\n' "$id" >"$inbox/$id"
  echo "herdr-say: queued message_id=$id" >&2
  exit 75
}

paste_pending_exit() {
  # Text already landed in the prompt from this call's paste, but the prompt state
  # changed (or Enter failed) before submission was verified safe. Never re-paste on
  # retry: a drain of a "pasted" message only rechecks safety and presses Enter.
  write_state pasted
  printf '%s\n' "$id" >"$inbox/$id"
  echo "herdr-say: paste landed, submission deferred message_id=$id" >&2
  exit 75
}

if dialog_open; then
  queue_and_exit
fi

if herdr agent send "$target" "$message$suffix" >/dev/null 2>&1 \
  || herdr agent send "$pane" "$message$suffix" >/dev/null 2>&1; then
  sleep 0.5
  if dialog_open; then
    paste_pending_exit
  fi
  if herdr pane run "$pane" "" >/dev/null 2>&1 && composer_cleared "$message"; then
    write_state submitted
    echo "message_id=$id status=submitted"
  else
    paste_pending_exit
  fi
else
  queue_and_exit
fi
