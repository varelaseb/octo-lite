#!/usr/bin/env bash
set -euo pipefail

target="${1:-}"
[[ -n "$target" ]] || { echo "usage: herdr-drain TARGET" >&2; exit 64; }
case "$target" in
  *:p*) pane="$target" ;;
  *) pane="$(herdr agent get "$target" 2>/dev/null | jq -r '.result.agent.pane_id // empty')" ;;
esac
[[ -n "$pane" ]] || exit 66

# herdr-drain never infers composer state, consumption, or delivery from pane
# transcript text. This read only detects a trust or safety dialog so an atomic
# prompt is never allowed to bulldoze an open modal; never the sent text itself.
dialog_open() {
  herdr pane read "$pane" --source visible --lines 40 2>/dev/null \
    | grep -qE 'Do you want|Do you trust|Quick safety check|trust this folder|Enter to confirm|to select|esc to cancel|❯ [0-9]+\.|❯ Yes|❯ No|\(y/n\)'
}

inbox="${XDG_STATE_HOME:-$HOME/.local/state}/octo-lite/inbox/$target"
[[ -d "$inbox" ]] || exit 0
for queued in "$inbox"/*; do
  [[ -f "$queued" ]] || continue
  lock="$queued.lock"
  exec 9>"$lock"
  flock -n 9 || { exec 9>&-; continue; }
  if [[ ! -f "$queued" ]]; then
    exec 9>&-
    continue
  fi
  id="$(<"$queued")"
  state="${XDG_STATE_HOME:-$HOME/.local/state}/octo-lite/messages/$id.toml"
  if [[ ! -f "$state" ]]; then
    rm -f "$queued" "$lock"
    exec 9>&-
    continue
  fi
  readarray -t values < <(python3 - "$state" <<'PY'
import sys, tomllib
with open(sys.argv[1], 'rb') as f:
    data = tomllib.load(f)
for key in ('target', 'kind', 'artifact', 'message', 'created_at', 'status'):
    print(data.get(key, ''))
PY
)
  suffix=""
  if [[ "${values[1]}" != "info" ]]; then
    suffix=" [msg:$id kind:${values[1]}] Acknowledge with: herdr-ack $id acknowledged --by $target"
  fi

  clear_retry() {
    rm -f "$queued" "$lock"
    echo "message_id=$id status=pending"
  }

  write_pending() {
    quote() { jq -Rn --arg value "$1" '$value'; }
    temporary="$state.$$.tmp"
    {
      echo 'schema_version = 1'
      echo "message_id = $(quote "$id")"
      echo "target = $(quote "${values[0]}")"
      echo "kind = $(quote "${values[1]}")"
      echo "status = $(quote pending)"
      echo "artifact = $(quote "${values[2]}")"
      echo "message = $(quote "${values[3]}")"
      echo "created_at = $(quote "${values[4]}")"
    } >"$temporary"
    mv "$temporary" "$state"
  }

  # Modal-safe: never fire an atomic prompt while a trust or safety dialog is
  # open; leave the pending/queued message in the inbox for the next retry.
  if dialog_open; then
    exec 9>&-
    exit 75
  fi

  if [[ "${values[5]}" == "pending" ]]; then
    # herdr 0.7.5: an earlier atomic prompt may not have landed. Retry the exact
    # same atomic prompt (paste + submit in one op); the atomic op never
    # double-submits partially-pasted text. Stays pending, in the inbox, for the
    # next retry unless this attempt's own atomic prompt succeeds.
    if herdr agent prompt "$pane" "${values[3]}$suffix" >/dev/null 2>&1; then
      clear_retry
    fi
  else
    # A queued (never-transported) message: fire the atomic prompt now. Persist
    # pending before dropping the retry item so a later herdr-ack sees pending,
    # not the stale queued status.
    if herdr agent prompt "$pane" "${values[3]}$suffix" >/dev/null 2>&1; then
      write_pending
      clear_retry
    fi
  fi
  exec 9>&-
done
