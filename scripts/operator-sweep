#!/usr/bin/env python3
from __future__ import annotations

import argparse
import hashlib
import json
import os
import subprocess
import sys
import tempfile
import tomllib
import uuid
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from octo_lite.launch import fetch_stream_binding, prepare_reconcile_launch, run_reconcile_launch  # noqa: E402

CANONICAL_SPEC_SIGNAL = "Canonical spec paths:"
CANONICAL_ADR_SIGNAL = "Canonical ADR paths:"


def atomic_write(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    handle, temporary = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    try:
        with os.fdopen(handle, "w", encoding="utf-8") as stream:
            stream.write(text)
            stream.flush()
            os.fsync(stream.fileno())
        os.replace(temporary, path)
    finally:
        if os.path.exists(temporary):
            os.unlink(temporary)


def load_toml(path: Path) -> dict:
    with path.open("rb") as stream:
        return tomllib.load(stream)


def repo_head(repo: Path) -> str:
    return subprocess.run(
        ["git", "-C", str(repo), "rev-parse", "HEAD"], check=True, capture_output=True, text=True,
    ).stdout.strip()


def _agents_md_text(repo: Path, head: str) -> str:
    kind = subprocess.run(
        ["git", "-C", str(repo), "cat-file", "-t", f"{head}:AGENTS.md"],
        capture_output=True, text=True,
    )
    if kind.returncode != 0 or kind.stdout.strip() != "blob":
        raise SystemExit("operator-sweep: target AGENTS.md missing at head")
    return subprocess.run(
        ["git", "-C", str(repo), "cat-file", "-p", f"{head}:AGENTS.md"],
        check=True, capture_output=True, text=True,
    ).stdout


def _signal_lines(text: str, signal: str) -> list[str]:
    values = []
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("- "):
            stripped = stripped[2:].strip()
        if stripped.startswith(signal):
            values.append(stripped[len(signal):].strip())
    return values


def _declared_paths(text: str, signal: str, *, label: str, allow_none: bool = False) -> list[str]:
    values = _signal_lines(text, signal)
    if len(values) == 0:
        raise SystemExit(f"operator-sweep: no canonical {label} paths declared")
    if len(values) > 1:
        raise SystemExit(f"operator-sweep: repeated canonical {label} paths declaration")
    value = values[0]
    if allow_none and value == "none":
        return []
    if not value:
        raise SystemExit(f"operator-sweep: no canonical {label} paths declared")
    entries = [entry.strip() for entry in value.split(",")]
    if any(not entry for entry in entries):
        raise SystemExit(f"operator-sweep: malformed canonical {label} declaration")
    if allow_none and any(entry == "none" for entry in entries):
        raise SystemExit(f"operator-sweep: malformed canonical {label} declaration")
    if len(set(entries)) != len(entries):
        raise SystemExit(f"operator-sweep: duplicate canonical {label} path declared")
    for entry in entries:
        segments = entry.split("/")
        if entry.startswith("/") or entry.startswith("~") or any(part in ("", "..", ".") for part in segments):
            raise SystemExit(f"operator-sweep: escaped canonical {label} path: {entry}")
    return entries


def _tree_entry(repo: Path, head: str, relative: str) -> tuple[str, str]:
    result = subprocess.run(
        ["git", "-C", str(repo), "ls-tree", head, "--", relative],
        capture_output=True, text=True,
    )
    line = result.stdout.strip()
    if result.returncode != 0 or not line:
        return "", ""
    fields = line.split()
    return fields[0], fields[1]


def canonical_blobs(repo: Path, head: str) -> tuple[list[str], list[str]]:
    text = _agents_md_text(repo, head)

    def bind(signal: str, label: str, *, allow_none: bool = False) -> list[str]:
        bound = []
        for relative in _declared_paths(text, signal, label=label, allow_none=allow_none):
            mode, kind = _tree_entry(repo, head, relative)
            if not kind:
                raise SystemExit(f"operator-sweep: canonical {label} path missing: {relative}")
            if mode == "120000":
                raise SystemExit(f"operator-sweep: canonical {label} path is a symlink: {relative}")
            if kind != "blob":
                raise SystemExit(f"operator-sweep: canonical {label} path is not a regular file: {relative}")
            size = subprocess.run(
                ["git", "-C", str(repo), "cat-file", "-s", f"{head}:{relative}"],
                check=True, capture_output=True, text=True,
            ).stdout.strip()
            if size == "0":
                raise SystemExit(f"operator-sweep: canonical {label} path is empty: {relative}")
            digest = subprocess.run(
                ["git", "-C", str(repo), "rev-parse", f"{head}:{relative}"],
                check=True, capture_output=True, text=True,
            ).stdout.strip()
            bound.append(f"{relative}:{digest}")
        return bound

    spec_bound = bind(CANONICAL_SPEC_SIGNAL, "spec")
    adr_bound = bind(CANONICAL_ADR_SIGNAL, "ADR", allow_none=True)
    spec_paths = {entry.split(":", 1)[0] for entry in spec_bound}
    adr_paths = {entry.split(":", 1)[0] for entry in adr_bound}
    if spec_paths & adr_paths:
        raise SystemExit("operator-sweep: canonical path declared as both spec and ADR")
    return spec_bound, adr_bound


def declared_stream_facts(stream_dir: Path) -> dict:
    sources_path = stream_dir / "sources.toml"
    if not sources_path.is_file():
        return {}
    declared = load_toml(sources_path)
    linear_decl = declared.get("linear")
    pr_decl = declared.get("pull_request")
    linear_issue = str(linear_decl["issue"]) if isinstance(linear_decl, dict) and linear_decl.get("issue") else None
    pr_repo = str(pr_decl["repo"]) if isinstance(pr_decl, dict) and pr_decl.get("repo") else None
    pr_number = int(pr_decl["number"]) if isinstance(pr_decl, dict) and pr_decl.get("number") else None
    facts: dict = {}
    if linear_issue or (pr_repo and pr_number):
        facts.update(fetch_stream_binding(linear_issue=linear_issue, pr_repo=pr_repo, pr_number=pr_number))
    for name in ("evidence", "deployment"):
        decl = declared.get(name)
        if isinstance(decl, dict) and decl.get("path"):
            artifact = Path(str(decl["path"]))
            facts[name] = {
                "path": str(decl["path"]),
                "hash": hashlib.sha256(artifact.read_bytes()).hexdigest() if artifact.is_file() else "missing",
            }
    return facts


def main() -> int:
    parser = argparse.ArgumentParser(description="Compact operator reconciliation sweep")
    parser.add_argument("--control-dir", type=Path, required=True)
    parser.add_argument("--owner-file", type=Path, required=True)
    parser.add_argument("--repo", type=Path, required=True)
    args = parser.parse_args()

    control = args.control_dir.resolve()
    repo = args.repo.resolve()
    owner_file = args.owner_file.resolve()
    owner = load_toml(owner_file)
    if owner.get("schema_version") != 1 or Path(str(owner.get("control_dir", ""))).resolve() != control:
        raise SystemExit("operator-sweep: control identity mismatch")
    owner_route = str(owner.get("owner_route") or "")
    if not owner_route:
        raise SystemExit("operator-sweep: owner missing")

    paths = ([control / "status.md"] if (control / "status.md").is_file() else [])
    stream_dirs = sorted((control / "streams").glob("*")) if (control / "streams").is_dir() else []
    paths.extend(sorted(path for stream_dir in stream_dirs for path in [stream_dir / "status.md"] if path.is_file()))
    parts = [f"## {path.relative_to(control)}\n{path.read_text().strip()}\n" for path in paths]

    # Every bound fact, including target HEAD and canonical spec/ADR blobs, is
    # refetched and validated before any unchanged decision or snapshot write, so
    # a drifted or invalid source can never hide behind an unchanged Linear
    # fingerprint or leave a persisted artifact behind on failure.
    head = repo_head(repo)
    spec_blobs, adr_blobs = canonical_blobs(repo, head)

    facts = {"owner_route": owner_route, "control_head": head, "canonical": {"spec_blobs": spec_blobs, "adr_blobs": adr_blobs}}
    streams = []
    for stream_dir in stream_dirs:
        stream_facts = declared_stream_facts(stream_dir)
        if stream_facts:
            facts[stream_dir.name] = stream_facts
        if "linear" in stream_facts or "pull_request" in stream_facts:
            entry = {"stream": stream_dir.name}
            if "linear" in stream_facts:
                entry["linear"] = stream_facts["linear"]
            if "pull_request" in stream_facts:
                entry["pull_request"] = stream_facts["pull_request"]
            streams.append(entry)
    normalized_facts = json.dumps(facts, sort_keys=True, separators=(",", ":"))

    snapshot = (
        "# Stream snapshot\n\n" + "\n".join(parts)
        + "\n## Declared facts\n\n" + normalized_facts + "\n"
    )
    fingerprint = hashlib.sha256(snapshot.encode()).hexdigest()
    state_path = control / "sweep-state.toml"
    prior = load_toml(state_path) if state_path.exists() else {}
    if prior.get("fingerprint") == fingerprint:
        print(json.dumps({"changed": False, "fingerprint": fingerprint, "owner": owner_route}))
        return 0

    sweep_dir = control / "sweeps" / fingerprint
    snapshot_path = sweep_dir / "snapshot.md"
    receipt_path = sweep_dir / "receipt.toml"
    result_path = sweep_dir / "result.md"

    root = Path(__file__).resolve().parents[1]
    worktree_root = control / "worktrees"
    worktree = worktree_root / fingerprint

    # snapshot.md is never persisted under the final sweep directory before the
    # gateway validates Linear, PR, HEAD, spec, and ADR facts, so a failing
    # gateway leaves no sweep artifact directory or state behind. A pending copy
    # outside that directory backs only the gateway's own independent digest
    # check and is removed on every failure.
    pending_snapshot_path = control / f".sweep-pending-{fingerprint}.md"
    atomic_write(pending_snapshot_path, snapshot)
    try:
        # Sole reconciler launch gateway: same worktree provisioning, containment,
        # and receipt binding as scripts/octo-launch, narrowed to the reconciler's
        # aggregate read-only shape. Fails closed before any provider call on
        # stale or substituted Linear, PR, spec, ADR, or repo HEAD input,
        # including a target HEAD that changed since head was captured above.
        prepared = prepare_reconcile_launch(
            root=root,
            spawn_id=str(uuid.uuid4()),
            parent=owner_route,
            reply_route="operator-say",
            repo=repo,
            worktree_root=worktree_root,
            worktree=worktree,
            receipt_path=receipt_path,
            execution_location=os.environ.get("OCTO_EXECUTION_LOCATION", "remote"),
            operator_loopback=os.environ.get("OCTO_OPERATOR_LOOPBACK", "false") == "true",
            review_delivery=os.environ.get("OCTO_REVIEW_DELIVERY", "reachable_url_required"),
            expected_head=head,
            snapshot_path=pending_snapshot_path,
            snapshot_digest=fingerprint,
            streams=streams,
            spec_blobs=spec_blobs,
            adr_blobs=adr_blobs,
            conversation_state_refs=[str(path.relative_to(control)) for path in paths],
        )
    except BaseException:
        pending_snapshot_path.unlink(missing_ok=True)
        raise
    atomic_write(snapshot_path, snapshot)
    pending_snapshot_path.unlink(missing_ok=True)

    judgment_prompt = (
        f"Bootstrap verified. Read snapshot {snapshot_path}. "
        "Classify only changed, missing, stale, contradictory, or needs_fable. "
        "Read only. Never mutate. Return a compact delta for the operator as plain text."
    )
    message = run_reconcile_launch(prepared, judgment_prompt)
    atomic_write(result_path, message)

    environment = dict(os.environ, OCTO_OPERATOR_OWNER=str(owner_file))
    delivered = subprocess.run(
        [
            "operator-say", "--kind", "info", "--artifact", str(result_path),
            f"Sweep delta ready: {result_path}",
        ],
        env=environment,
        check=False,
    )
    if delivered.returncode not in {0, 75}:
        raise SystemExit(delivered.returncode)

    atomic_write(
        state_path,
        "schema_version = 1\n"
        f"fingerprint = {json.dumps(fingerprint)}\n"
        f"owner_route = {json.dumps(owner_route)}\n"
        f"snapshot = {json.dumps(str(snapshot_path))}\n"
        f"receipt = {json.dumps(str(receipt_path))}\n"
        f"result = {json.dumps(str(result_path))}\n",
    )
    print(json.dumps({"changed": True, "fingerprint": fingerprint, "owner": owner_route, "result": str(result_path)}))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
