#!/usr/bin/env python3
"""Lean operator heartbeat (#23, #22 rulings 1/3/10/11).

A wake is a lean heartbeat (supervision-sweep): it regenerates a FRESH operator
snapshot from current facts (heartbeat-fresh-snapshot), spawns no reconciler
subprocess, and binds no target canonical specs, so it NEVER fails closed on
target-repo shape. The heartbeat reports one layer down only, per orchestrator
(heartbeat-one-layer): its stream, its last delivery or forward-progress
marker, and any operator-gated state; worker-level liveness is the
orchestrator's own duty and is never probed or classified here
(heartbeat-judgment-in-roles). The snapshot lives in the heartbeat output and
ONE control-level file, never a persisted authoritative current-state record
(heartbeat-outside-digest).

Operator-gated states surface loudly on every wake (heartbeat-operator-gate /
sweep-operator-gate-unsuppressible): the loud lines print to stdout and into the
delivered snapshot every cycle, and the edge-triggered pane ping fires once per
new/changed gate set (sweep-operator-gate-edge / edge-retry). Operator asks
(sweep-operator-ask), stalled transport (sweep-transport-stalled), and the
registry-lite advisory (sweep-registry-drift) still surface.
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
import tomllib
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

# The heartbeat reads one non-reconcile fact per carried issue: its live Linear
# state, so an operator-gated state can surface. It never spawns a reconciler
# and never binds target canonical specs.
from octo_lite.launch import fetch_stream_binding  # noqa: E402

# ---- TUR-505 phase-1 message transport laws (E1/P1/S3/G2-lite) ----
#
# Transport class: bounded duplicate-prone transport with NO delivery
# guarantee; a message may be delivered zero times, once, or up to the attempt
# cap per epoch. The sweep's stalled/undelivered surfacing is the no-delivery
# detection path.
MESSAGE_ID_RE = re.compile(r"^[0-9]{8}T[0-9]{6}-[0-9]+-[0-9]+$")
MESSAGE_TARGET_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]*(:[A-Za-z0-9]+)?$")
RETRYABLE_PATHS = {"modal-queued", "deferred"}
ACK_WAIT_PATHS = {"direct", "unresolved-ask"}
_LEGACY_NOTE_CAP = 20


def _positive_int_env(name: str, default: int) -> tuple[int, str]:
    """Positive-int env knob: invalid value degrades to the default with a
    distinct warning note (OCTO_TRANSPORT_ATTEMPT_CAP / OCTO_PUBLICATION_REPAIR_SECONDS)."""
    raw = os.environ.get(name, "")
    if not raw:
        return default, ""
    if raw.isdigit() and int(raw) > 0:
        return int(raw), ""
    return default, f"SWEEP NOTE (invalid env): {name}='{raw}' invalid, using default {default}"


def _load_message_state(path: Path) -> dict | None:
    try:
        with path.open("rb") as stream:
            state = tomllib.load(stream)
    except Exception:
        return None
    return state if isinstance(state, dict) else None


def transport_message_report(messages_root: Path, inbox_root: Path, locks_root: Path, *, now: float | None = None) -> dict:
    """S3 stalled surfacing + P1 publication repair over the durable message
    states. Stalled messages emit a loud transport-stalled line EVERY cycle
    (unsuppressible family) until resumed or acked. A RETRYABLE state
    (queued|pending with delivery_path modal-queued|deferred) with no inbox
    item whose state-file mtime is older than OCTO_PUBLICATION_REPAIR_SECONDS
    gets its item recreated (content = id) under the permanent message lock.
    delivery_path direct or unresolved-ask is NEVER repaired; legacy states
    without delivery_path are never guess-repaired, only noted
    undelivered-unknown-legacy (capped)."""
    import fcntl

    current = time.time() if now is None else now
    repair_seconds, repair_warn = _positive_int_env("OCTO_PUBLICATION_REPAIR_SECONDS", 180)
    stalled_lines: list[str] = []
    repair_notes: list[str] = []
    legacy_notes: list[str] = []
    warnings: list[str] = [repair_warn] if repair_warn else []
    if not messages_root.is_dir():
        return {"stalled_lines": [], "repair_notes": [], "legacy_notes": [], "warnings": warnings}
    for state_path in sorted(messages_root.glob("*.toml")):
        if not MESSAGE_ID_RE.match(state_path.stem):
            continue
        state = _load_message_state(state_path)
        if state is None:
            continue
        message_id = state_path.stem
        status = str(state.get("status") or "")
        target = str(state.get("target") or "")
        path = str(state.get("delivery_path") or "")
        if status == "stalled":
            attempts = state.get("transport_attempts", 0)
            stalled_lines.append(
                f"TRANSPORT STALLED: message {message_id} target={target} "
                f"attempts={attempts} - resume with herdr-drain --resume {message_id} or ack"
            )
            continue
        if status not in {"queued", "pending"}:
            continue
        if path in ACK_WAIT_PATHS:
            continue  # ACK-WAIT by construction: never repaired.
        if not path:
            # Legacy state without delivery_path: no guess-repair for itemless
            # ones; drain's legacy promotion keeps live items firing.
            if MESSAGE_TARGET_RE.match(target):
                item = inbox_root / target / message_id
                if item.is_file():
                    continue
            if len(legacy_notes) < _LEGACY_NOTE_CAP:
                legacy_notes.append(
                    f"SWEEP NOTE (undelivered-unknown-legacy): message {message_id} "
                    "has no delivery_path and no inbox item, not repaired"
                )
            elif len(legacy_notes) == _LEGACY_NOTE_CAP:
                legacy_notes.append("SWEEP NOTE (undelivered-unknown-legacy): further legacy messages elided")
            continue
        if path not in RETRYABLE_PATHS:
            continue
        # L3 target grammar (ruling-87 fold): validated BEFORE deriving any
        # path, so ../../escape:p1 can never traverse out of the inbox root.
        if not MESSAGE_TARGET_RE.match(target):
            repair_notes.append(
                f"SWEEP NOTE (invalid target): message {message_id} target rejected, not repaired"
            )
            continue
        item = inbox_root / target / message_id
        if item.is_file():
            continue
        try:
            mtime = state_path.stat().st_mtime
        except OSError:
            continue
        if (current - mtime) <= repair_seconds:
            continue  # Fresh publication window: not repaired yet.
        # P1 repair under the permanent message lock (skip when held; the next
        # cycle retries, bounded by construction).
        locks_root.mkdir(parents=True, exist_ok=True)
        lock_path = locks_root / f"{message_id}.lock"
        try:
            with lock_path.open("a") as lock_handle:
                try:
                    fcntl.flock(lock_handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
                except OSError:
                    continue
                # Re-verify under the lock before recreating the item.
                state = _load_message_state(state_path)
                if not isinstance(state, dict):
                    continue
                if str(state.get("status") or "") not in {"queued", "pending"}:
                    continue
                if str(state.get("delivery_path") or "") not in RETRYABLE_PATHS:
                    continue
                if item.is_file():
                    continue
                item.parent.mkdir(parents=True, exist_ok=True)
                temporary = item.parent / f".{message_id}.tmp"
                temporary.write_text(message_id + "\n")
                temporary.replace(item)
                repair_notes.append(
                    f"SWEEP NOTE (publication repair): recreated inbox item {target}/{message_id}"
                )
        except OSError:
            continue
    return {
        "stalled_lines": stalled_lines,
        "repair_notes": repair_notes,
        "legacy_notes": legacy_notes,
        "warnings": warnings,
    }


def registry_lite_advisories(control: Path, owner_route: str) -> list[str]:
    """G2-lite (ruling-86 second split): one `herdr agent list` call per sweep;
    each live agent lacking streams/<name>/stream.toml gets an ADVISORY-marked
    note. Explicitly NEVER an OPERATOR ACTION line and exempt from the
    nothing-suppresses-gates law in both directions. owner_route and
    OCTO_REGISTRY_EXEMPT names are exempt. Degrades gracefully to no
    advisories on any failure."""
    herdr = os.environ.get("OCTO_HERDR") or shutil.which("herdr")
    if not herdr:
        return []
    try:
        result = subprocess.run(
            [herdr, "agent", "list"], capture_output=True, text=True, timeout=3,
        )
    except (subprocess.SubprocessError, OSError):
        return []
    if result.returncode != 0:
        return []
    try:
        payload = json.loads(result.stdout) if result.stdout.strip() else {}
    except ValueError:
        return []
    if not isinstance(payload, dict):
        return []
    result_obj = payload.get("result")
    agents = result_obj.get("agents") if isinstance(result_obj, dict) else None
    if not isinstance(agents, list):
        return []
    exempt = {owner_route}
    exempt.update(name.strip() for name in os.environ.get("OCTO_REGISTRY_EXEMPT", "").split(",") if name.strip())
    advisories: list[str] = []
    for entry in agents:
        if not isinstance(entry, dict):
            continue
        name = str(entry.get("name") or entry.get("agent_name") or "")
        if not name or name in exempt:
            continue
        if (control / "streams" / name / "stream.toml").is_file():
            continue
        advisories.append(
            f"ADVISORY (registry-lite): live agent {name} lacks streams/{name}/stream.toml"
        )
    return advisories


def atomic_write(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    handle, temporary = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    try:
        with os.fdopen(handle, "w", encoding="utf-8") as stream:
            stream.write(text)
            stream.flush()
            os.fsync(stream.fileno())
        os.replace(temporary, path)
    finally:
        if os.path.exists(temporary):
            os.unlink(temporary)


def load_toml(path: Path) -> dict:
    with path.open("rb") as stream:
        return tomllib.load(stream)


# Operator-gated Linear states (sweep-operator-gated-set): the acceptance state
# plus this target's operator-owned promotion states, excluding the terminal
# live state, the accepted-and-merged transient, and every agent/mechanical
# state.
OPERATOR_GATED_STATES = {"Awaiting Accept", "In Staging", "In Preprod"}
# One-line operator action per gated state (heartbeat-operator-gate).
OPERATOR_GATE_ACTION = {
    "Awaiting Accept": "accept or reject the delivered work",
    "In Staging": "verify staging then promote or hold",
    "In Preprod": "authorize the live traffic shift or hold",
}


def _carried_issues(linear_decl) -> list[str]:
    """A stream may declare a single `issue = "..."` (back-compat) and/or a
    LIST `issues = ["...", "..."]`; every carried issue is read (sweep-carried-issues)."""
    issues: list[str] = []
    if isinstance(linear_decl, dict):
        if linear_decl.get("issue"):
            issues.append(str(linear_decl["issue"]))
        raw_list = linear_decl.get("issues")
        if isinstance(raw_list, list):
            for entry in raw_list:
                if entry:
                    issues.append(str(entry))
    seen: set[str] = set()
    ordered: list[str] = []
    for issue in issues:
        if issue not in seen:
            seen.add(issue)
            ordered.append(issue)
    return ordered


_TUR_TOKEN = re.compile(r"\b([A-Za-z]+-\d+)\b")


def _normalize_issue(token: str) -> str:
    """Normalize a carried-issue token to canonical upper prefix (TUR-479)."""
    return token.upper()


def _envelope_carried_issues(stream_dir: Path) -> list[str]:
    """Derive carried issues from every review/delivery envelope in the stream:
    each *envelope*.toml with a top-level string `issue = "TUR-<n>"` (sweep-
    carried-issues). Real production streams have no sources.toml; the shaping,
    code, and delivery review envelopes carry the bound issue at top level."""
    issues: list[str] = []
    for path in sorted(stream_dir.glob("*envelope*.toml")):
        try:
            envelope = load_toml(path)
        except Exception:
            continue
        value = envelope.get("issue")
        if isinstance(value, str) and value.strip():
            issues.append(_normalize_issue(value.strip()))
    return issues


def _status_line_carried_issues(stream_dir: Path) -> list[str]:
    """Derive carried issues from the stream status.md ANCHORED `Issues:` line
    only (sweep-carried-issues). CRITICAL noise guard: only the anchored
    `^Issues:` line is parsed; free prose TUR-ids elsewhere in the roadmap
    status are never scanned or surfaced."""
    status_path = stream_dir / "status.md"
    if not status_path.is_file():
        return []
    try:
        text = status_path.read_text()
    except Exception:
        return []
    match = re.search(r"^Issues:\s*(.+)$", text, re.MULTILINE)
    if not match:
        return []
    return [_normalize_issue(token) for token in _TUR_TOKEN.findall(match.group(1))]


def _derive_carried_issues(stream_dir: Path, linear_decl) -> list[str]:
    """Union of carried issues in priority order (sweep-carried-issues): explicit
    sources.toml [linear] issue/issues, then every review/delivery envelope's
    top-level issue, then the status.md anchored `Issues:` line. Deduped, case-
    insensitive TUR match, normalized to upper. Only structured declarations are
    read; free prose is never scanned."""
    ordered: list[str] = []
    seen: set[str] = set()
    for issue in (
        *_carried_issues(linear_decl),
        *_envelope_carried_issues(stream_dir),
        *_status_line_carried_issues(stream_dir),
    ):
        key = issue.upper()
        if key not in seen:
            seen.add(key)
            ordered.append(issue)
    return ordered


# Read failures we tolerate around a single carried-issue Linear read so one bad
# issue (rate-limit, network, deleted issue, missing auth) never crashes the whole
# sweep and takes down the live timer (sweep-graceful-degradation). Programming
# errors in our own code path are NOT swallowed; only external read failures are.
_CARRIED_READ_ERRORS: tuple[type[BaseException], ...] = (
    subprocess.CalledProcessError,
    subprocess.SubprocessError,
    OSError,
    ValueError,
)


def declared_stream_facts(stream_dir: Path) -> dict:
    """Read every carried issue's live Linear state (a plain fact read, never a
    reconciler subprocess) so an operator-gated state can surface. Each carried
    read is guarded: one external read failure is recorded and skipped, never a
    crash (sweep-graceful-degradation)."""
    sources_path = stream_dir / "sources.toml"
    declared = load_toml(sources_path) if sources_path.is_file() else {}
    linear_decl = declared.get("linear")
    carried = _derive_carried_issues(stream_dir, linear_decl)
    facts: dict = {}
    read_errors: list[dict] = []
    carried_linear: list[dict] = []
    for issue in carried:
        try:
            binding = fetch_stream_binding(linear_issue=issue, pr_repo=None, pr_number=None)
        except _CARRIED_READ_ERRORS as error:
            read_errors.append({"issue": issue, "error": str(error)})
            continue
        if isinstance(binding, dict) and binding.get("linear"):
            carried_linear.append(binding["linear"])
    if carried_linear:
        facts["carried_linear"] = carried_linear
    if read_errors:
        facts["carried_read_errors"] = read_errors
    return facts


def _gated_carried_states(stream_facts: dict) -> list[tuple[str, str]]:
    """Every (issue_id, state) a stream carries whose state is operator-gated."""
    gated: list[tuple[str, str]] = []
    for binding in stream_facts.get("carried_linear") or []:
        state = str(binding.get("state") or "")
        identifier = str(binding.get("identifier") or "")
        if identifier and state in OPERATOR_GATED_STATES:
            gated.append((identifier, state))
    return gated


def operator_waits(waits_root: Path, stream_name: str) -> list[dict]:
    """Source B substrate (sweep-operator-ask): a mechanical per-stream stamp the
    lane operator-ask path writes when it sends a --kind question to the operator
    route, cleared by the operator answer relay (herdr-ack). Read structurally,
    never from pane transcript text, so detection is modal-safe."""
    stamp_path = waits_root / f"{stream_name}.toml"
    if not stamp_path.is_file():
        return []
    try:
        stamp = load_toml(stamp_path)
    except Exception:
        return []
    if str(stamp.get("owner") or "") != "operator":
        return []
    ask = str(stamp.get("ask") or "").strip()
    if not ask:
        return []
    return [{"ask": ask, "message_id": str(stamp.get("message_id") or "")}]


def operator_gate_lines(stream_dirs: list[Path], facts: dict, waits_root: Path) -> list[str]:
    """Loud, unsuppressible operator-gate block (heartbeat-operator-gate /
    sweep-operator-gate-unsuppressible). Source A is every carried issue in an
    operator-gated Linear state; Source B is every open unanswered operator ask.
    A gate surfaces regardless of the stream's lifecycle standing
    (sweep-gate-surfaces-regardless), because the heartbeat assigns no liveness
    classification of its own."""
    lines: list[str] = []
    for stream_dir in stream_dirs:
        stream_facts = facts.get(stream_dir.name)
        if isinstance(stream_facts, dict):
            for identifier, state in _gated_carried_states(stream_facts):
                action = OPERATOR_GATE_ACTION.get(state, "review and act")
                lines.append(f"OPERATOR ACTION NEEDED: {identifier} {state} - {action}")
        for wait in operator_waits(waits_root, stream_dir.name):
            lines.append(f"OPERATOR ACTION NEEDED: {stream_dir.name} asks: {wait['ask']}")
    return lines


def degraded_read_notes(stream_dirs: list[Path], facts: dict) -> list[str]:
    """Distinct, clearly-labeled degraded-read notes (sweep-graceful-degradation):
    one per carried issue whose Linear read failed and was skipped. Deliberately NOT
    an `OPERATOR ACTION NEEDED` gate line: a transient read failure must never be
    mistaken for an operator gate."""
    notes: list[str] = []
    for stream_dir in stream_dirs:
        stream_facts = facts.get(stream_dir.name)
        if not isinstance(stream_facts, dict):
            continue
        for entry in stream_facts.get("carried_read_errors") or []:
            issue = str(entry.get("issue") or "")
            notes.append(
                f"SWEEP NOTE (degraded read): {stream_dir.name} skipped {issue} - "
                "linear read failed, other carried issues still read"
            )
    return notes


def sanitize_project_dir(cwd: str) -> str:
    """Claude session transcripts live under ~/.claude/projects/<sanitized-cwd>/;
    the sanitized name replaces every non-alphanumeric character with a dash."""
    return re.sub(r"[^A-Za-z0-9]", "-", cwd)


def _stream_transcript_paths(stream_dir: Path, projects_root: Path) -> list[Path]:
    """Resolve every session transcript a stream's receipts point at: each
    receipt*.toml's session id plus workspace cwd derives
    <projects_root>/<sanitized-cwd>/<session_id>.jsonl. A stream may carry an
    original receipt for a closed session plus a newer receipt for the active
    one; forward-progress considers them all."""
    paths: list[Path] = []
    for receipt_path in sorted(stream_dir.glob("receipt*.toml")):
        try:
            receipt = load_toml(receipt_path)
        except Exception:
            continue
        session_id = str(receipt.get("bootstrap", {}).get("provider_session_id") or "")
        worktree = str(receipt.get("workspace", {}).get("worktree") or "")
        if session_id and worktree:
            paths.append(projects_root / sanitize_project_dir(worktree) / f"{session_id}.jsonl")
    return paths


# The anchored delivery line a stream's own status.md records; the heartbeat
# surfaces it verbatim as the last-delivery marker, never interpreting it.
_DELIVERY_LINE = re.compile(r"^(?:Last delivery|Delivered):\s*(.+)$", re.MULTILINE)


def stream_snapshot(stream_dir: Path, facts: dict, waits_root: Path, *, projects_root: Path | None = None) -> dict:
    """One-layer-down heartbeat fact for a single orchestrator stream
    (heartbeat-fresh-snapshot / heartbeat-one-layer): its stream name, its last
    delivery OR forward-progress marker (derived from a real observable - the
    receipt-derived session transcript mtime and the status.md anchored delivery
    line), and any operator-gated state. It carries NO classification or judgment
    of its own (heartbeat-judgment-in-roles); worker-level liveness is never
    probed or classified here."""
    projects = projects_root if projects_root is not None else Path.home() / ".claude" / "projects"

    def mtime(path: Path) -> int | None:
        try:
            return int(path.stat().st_mtime) if path.is_file() else None
        except OSError:
            return None

    transcript_mtimes = [
        value
        for value in (mtime(path) for path in _stream_transcript_paths(stream_dir, projects))
        if value is not None
    ]
    forward_progress = max(transcript_mtimes) if transcript_mtimes else None

    status_path = stream_dir / "status.md"
    last_delivery = ""
    if status_path.is_file():
        try:
            match = _DELIVERY_LINE.search(status_path.read_text())
        except OSError:
            match = None
        if match:
            last_delivery = match.group(1).strip()

    gate_reasons: list[str] = []
    stream_facts = facts.get(stream_dir.name)
    if isinstance(stream_facts, dict):
        for identifier, state in _gated_carried_states(stream_facts):
            action = OPERATOR_GATE_ACTION.get(state, "review and act")
            gate_reasons.append(f"{identifier} {state} - {action}")
    for wait in operator_waits(waits_root, stream_dir.name):
        gate_reasons.append(f"asks: {wait['ask']}")

    return {
        "stream": stream_dir.name,
        "forward_progress_mtime": forward_progress,
        "last_delivery": last_delivery,
        "operator_gate": gate_reasons,
    }


def _emit_operator_gate(gate_lines: list[str], root: Path, owner_file: Path, owner_route: str, state_dir: Path) -> None:
    """Surface the loud operator-gate block: print every line to stdout every cycle
    (the sweep ALWAYS shows current gates, unsuppressible), but push the loud ping
    to the OPERATOR PANE only when the gate SET CHANGES (edge-triggered,
    sweep-operator-gate-edge / edge-retry). A persistent gate (e.g. an issue parked
    In Staging for hours) must not re-ping the operator every cycle; the pane ping
    fires once on a new/changed gate set and is re-armed when the set clears or
    changes. The stdout surface is never suppressed."""
    marker = state_dir / ".operator-gate-last"
    if not gate_lines:
        # Gate set now empty: clear the marker so the next gate re-pings.
        marker.unlink(missing_ok=True)
        return
    for line in gate_lines:
        print(line)
    fingerprint = hashlib.sha256("\n".join(sorted(gate_lines)).encode("utf-8")).hexdigest()
    try:
        previous = marker.read_text(encoding="utf-8").strip()
    except FileNotFoundError:
        previous = ""
    if previous == fingerprint:
        return  # Unchanged gate set: already pinged the operator, do not re-flood.
    environment = dict(os.environ, OCTO_OPERATOR_OWNER=str(owner_file))
    operator_say = os.environ.get("OCTO_OPERATOR_SAY") or str(root / "skills/herdr-comms/assets/operator-say")
    handle, temporary = tempfile.mkstemp(prefix=".operator-gate-", suffix=".md")
    try:
        with os.fdopen(handle, "w", encoding="utf-8") as stream:
            stream.write("\n".join(gate_lines) + "\n")
        result = subprocess.run(
            [operator_say, "--kind", "info", "--artifact", temporary, "Operator gate"],
            env=environment,
            check=False,
        )
        # Persist the marker only when the operator will see it (delivered rc=0 or
        # queued-at-modal rc=75); on a hard failure leave it unwritten so the next
        # pass retries rather than silently dropping a NEW gate.
        if result.returncode in (0, 75):
            marker.write_text(fingerprint + "\n", encoding="utf-8")
    finally:
        if os.path.exists(temporary):
            os.unlink(temporary)


def main() -> int:
    parser = argparse.ArgumentParser(description="Lean operator heartbeat")
    parser.add_argument("--control-dir", type=Path, required=True)
    parser.add_argument("--owner-file", type=Path, required=True)
    # --repo is retained for invocation-surface compatibility with the timer;
    # the lean heartbeat never binds target canonical specs, so it is not read.
    parser.add_argument("--repo", type=Path, required=False)
    args = parser.parse_args()

    control = args.control_dir.resolve()
    owner_file = args.owner_file.resolve()
    owner = load_toml(owner_file)
    if owner.get("schema_version") != 1 or Path(str(owner.get("control_dir", ""))).resolve() != control:
        raise SystemExit("operator-sweep: control identity mismatch")
    owner_route = str(owner.get("owner_route") or "")
    if not owner_route:
        raise SystemExit("operator-sweep: owner missing")

    root = Path(__file__).resolve().parents[1]
    stream_dirs = sorted((control / "streams").glob("*")) if (control / "streams").is_dir() else []

    xdg_state = Path(os.environ.get("XDG_STATE_HOME") or str(Path.home() / ".local/state")) / "octo-lite"
    inbox_root = xdg_state / "inbox"
    messages_root = xdg_state / "messages"
    waits_root = xdg_state / "operator-waits"
    locks_root = xdg_state / "locks"

    # Fresh snapshot regenerated from current facts on every wake
    # (heartbeat-fresh-snapshot). Nothing persisted is trusted as current state.
    facts: dict = {}
    snapshot: list[dict] = []
    for stream_dir in stream_dirs:
        stream_facts = declared_stream_facts(stream_dir)
        if stream_facts:
            facts[stream_dir.name] = stream_facts
    for stream_dir in stream_dirs:
        snapshot.append(stream_snapshot(stream_dir, facts, waits_root))

    gate_lines = operator_gate_lines(stream_dirs, facts, waits_root)
    degraded_notes = degraded_read_notes(stream_dirs, facts)

    # Transport + registry surfaces (sweep-transport-stalled / sweep-registry-drift):
    # loud stalled lines every cycle, plus the one-agent-list registry advisory.
    transport = transport_message_report(messages_root, inbox_root, locks_root)
    transport_lines = transport["stalled_lines"] + transport["repair_notes"] + transport["warnings"]
    registry_advisories = registry_lite_advisories(control, owner_route)

    # The snapshot lives in the heartbeat output AND one control-level file, never
    # a persisted authoritative current-state record (heartbeat-outside-digest).
    atomic_write(control / "snapshot.json", json.dumps(snapshot, sort_keys=True, indent=1) + "\n")

    # A changed heartbeat is one whose gate set OR snapshot changed since the last
    # wake; only a changed heartbeat should draw the operator's eye (supervision-
    # timer). The gate surface itself is unsuppressible regardless.
    fingerprint = hashlib.sha256(
        json.dumps({"snapshot": snapshot, "gate": sorted(gate_lines)}, sort_keys=True).encode()
    ).hexdigest()
    state_path = control / "sweep-state.toml"
    prior = load_toml(state_path) if state_path.exists() else {}
    changed = prior.get("fingerprint") != fingerprint

    # Loud operator-gate surface every cycle: stdout is unsuppressible, the pane
    # ping is edge-triggered (sweep-operator-gate-unsuppressible / -edge).
    _emit_operator_gate(gate_lines, root, owner_file, owner_route, control)
    for note in degraded_notes:
        print(note)
    for line in transport_lines:
        print(line)
    for advisory in registry_advisories:
        print(advisory, file=sys.stderr)

    atomic_write(
        state_path,
        "schema_version = 1\n"
        f"fingerprint = {json.dumps(fingerprint)}\n"
        f"owner_route = {json.dumps(owner_route)}\n",
    )

    print(json.dumps({
        "changed": changed,
        "fingerprint": fingerprint,
        "owner": owner_route,
        "snapshot": snapshot,
        "operator_gate": gate_lines,
        "degraded_reads": degraded_notes,
        "transport_stalled": transport["stalled_lines"],
        "transport_repairs": transport["repair_notes"],
        "transport_legacy": transport["legacy_notes"],
        "registry_advisories": registry_advisories,
    }))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
