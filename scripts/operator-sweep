#!/usr/bin/env python3
from __future__ import annotations

import argparse
import hashlib
import json
import os
import subprocess
import sys
import tempfile
import tomllib
import uuid
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from octo_lite.launch import parse_provider_message, prepared_from_receipt, run_bootstrap  # noqa: E402
from octo_lite.runtime import bind_pass_result  # noqa: E402
from workflows.lib.role_resolver import build_launch_receipt, load_registry, render_receipt, resolve_role  # noqa: E402


def atomic_write(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    handle, temporary = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    try:
        with os.fdopen(handle, "w", encoding="utf-8") as stream:
            stream.write(text)
            stream.flush()
            os.fsync(stream.fileno())
        os.replace(temporary, path)
    finally:
        if os.path.exists(temporary):
            os.unlink(temporary)


def load_toml(path: Path) -> dict:
    with path.open("rb") as stream:
        return tomllib.load(stream)


def run_json(argv: list[str]) -> dict:
    result = subprocess.run(argv, check=True, capture_output=True, text=True)
    return json.loads(result.stdout)


def read_linear_fact(issue: str) -> dict:
    raw = run_json(["linear", "issue", "view", issue, "--json", "--no-download"])
    state = raw.get("state")
    return {
        "identifier": raw.get("identifier"),
        "state": state.get("name") if isinstance(state, dict) else state,
        "updated_at": raw.get("updatedAt"),
    }


def read_pr_fact(repo: str, number: int) -> dict:
    raw = run_json(
        [
            "gh", "pr", "view", str(number), "--repo", repo, "--json",
            "headRefOid,state,reviewDecision,statusCheckRollup",
        ]
    )
    return {
        "head": raw.get("headRefOid"),
        "state": raw.get("state"),
        "review": raw.get("reviewDecision") or "",
        "ci": raw.get("statusCheckRollup") or [],
    }


def declared_stream_facts(stream_dir: Path) -> dict:
    sources_path = stream_dir / "sources.toml"
    if not sources_path.is_file():
        return {}
    declared = load_toml(sources_path)
    facts: dict = {}
    linear_decl = declared.get("linear")
    if isinstance(linear_decl, dict) and linear_decl.get("issue"):
        facts["linear"] = read_linear_fact(str(linear_decl["issue"]))
    pr_decl = declared.get("pull_request")
    if isinstance(pr_decl, dict) and pr_decl.get("repo") and pr_decl.get("number"):
        facts["pull_request"] = read_pr_fact(str(pr_decl["repo"]), int(pr_decl["number"]))
    for name in ("evidence", "deployment"):
        decl = declared.get(name)
        if isinstance(decl, dict) and decl.get("path"):
            artifact = Path(str(decl["path"]))
            facts[name] = {
                "path": str(decl["path"]),
                "hash": hashlib.sha256(artifact.read_bytes()).hexdigest() if artifact.is_file() else "missing",
            }
    return facts


def main() -> int:
    parser = argparse.ArgumentParser(description="Compact operator reconciliation sweep")
    parser.add_argument("--control-dir", type=Path, required=True)
    parser.add_argument("--owner-file", type=Path, required=True)
    parser.add_argument("--repo", type=Path, required=True)
    args = parser.parse_args()

    control = args.control_dir.resolve()
    repo = args.repo.resolve()
    owner_file = args.owner_file.resolve()
    owner = load_toml(owner_file)
    if owner.get("schema_version") != 1 or Path(str(owner.get("control_dir", ""))).resolve() != control:
        raise SystemExit("operator-sweep: control identity mismatch")
    owner_session = str(owner.get("owner_session") or "")
    if not owner_session:
        raise SystemExit("operator-sweep: owner missing")

    paths = ([control / "status.md"] if (control / "status.md").is_file() else [])
    stream_dirs = sorted((control / "streams").glob("*")) if (control / "streams").is_dir() else []
    paths.extend(sorted(path for stream_dir in stream_dirs for path in [stream_dir / "status.md"] if path.is_file()))
    parts = [f"## {path.relative_to(control)}\n{path.read_text().strip()}\n" for path in paths]

    facts = {"owner_session": owner_session}
    for stream_dir in stream_dirs:
        stream_facts = declared_stream_facts(stream_dir)
        if stream_facts:
            facts[stream_dir.name] = stream_facts
    normalized_facts = json.dumps(facts, sort_keys=True, separators=(",", ":"))

    snapshot = (
        "# Stream snapshot\n\n" + "\n".join(parts)
        + "\n## Declared facts\n\n" + normalized_facts + "\n"
    )
    fingerprint = hashlib.sha256(snapshot.encode()).hexdigest()
    state_path = control / "sweep-state.toml"
    prior = load_toml(state_path) if state_path.exists() else {}
    if prior.get("fingerprint") == fingerprint:
        print(json.dumps({"changed": False, "fingerprint": fingerprint, "owner": owner_session}))
        return 0

    sweep_dir = control / "sweeps" / fingerprint
    snapshot_path = sweep_dir / "snapshot.md"
    receipt_path = sweep_dir / "receipt.toml"
    result_path = sweep_dir / "result.md"
    atomic_write(snapshot_path, snapshot)

    root = Path(__file__).resolve().parents[1]
    registry = load_registry(root)
    resolved = resolve_role(registry, "reconciler", set())
    receipt = build_launch_receipt(
        root,
        resolved,
        spawn_id=str(uuid.uuid4()),
        parent=owner_session,
        reply_route="operator-say",
        repo=repo,
        worktree=repo,
        execution_location=os.environ.get("OCTO_EXECUTION_LOCATION", "remote"),
        operator_loopback=os.environ.get("OCTO_OPERATOR_LOOPBACK", "false") == "true",
        review_delivery=os.environ.get("OCTO_REVIEW_DELIVERY", "reachable_url_required"),
    )
    atomic_write(receipt_path, render_receipt(receipt))

    # Phase 1: parent-controlled read-only bootstrap. The reconciler cannot read or
    # judge the snapshot yet; it only self-verifies the receipt and acknowledges.
    prepared = prepared_from_receipt(receipt, receipt_path, resolved.contract_text)
    session_id = run_bootstrap(prepared)

    # Phase 2: resume the exact bootstrap-verified session with the bounded snapshot
    # for the read-only judgment pass.
    judgment_prompt = (
        f"Bootstrap verified. Read snapshot {snapshot_path}. "
        "Classify only changed, missing, stale, contradictory, or needs_fable. "
        "Read only. Never mutate. Return a compact delta for the operator as plain text."
    )
    judgment = subprocess.run(
        prepared.mutation_argv_for(session_id),
        cwd=repo,
        input=judgment_prompt,
        capture_output=True,
        text=True,
        check=False,
    )
    if judgment.returncode != 0:
        raise SystemExit(f"operator-sweep: reconciler judgment failed: {judgment.stderr.strip()}")
    _, message = parse_provider_message(receipt["runtime"]["provider"], judgment.stdout)
    bind_pass_result(receipt_path, "reconciler", {"message": message})
    atomic_write(result_path, message)

    environment = dict(os.environ, OCTO_OPERATOR_OWNER=str(owner_file))
    delivered = subprocess.run(
        [
            "operator-say", "--kind", "info", "--artifact", str(result_path),
            f"Sweep delta ready: {result_path}",
        ],
        env=environment,
        check=False,
    )
    if delivered.returncode not in {0, 75}:
        raise SystemExit(delivered.returncode)

    atomic_write(
        state_path,
        "schema_version = 1\n"
        f"fingerprint = {json.dumps(fingerprint)}\n"
        f"owner_session = {json.dumps(owner_session)}\n"
        f"snapshot = {json.dumps(str(snapshot_path))}\n"
        f"receipt = {json.dumps(str(receipt_path))}\n"
        f"result = {json.dumps(str(result_path))}\n",
    )
    print(json.dumps({"changed": True, "fingerprint": fingerprint, "owner": owner_session, "result": str(result_path)}))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
