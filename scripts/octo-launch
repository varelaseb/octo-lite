#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import subprocess
import sys
import tomllib
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from octo_lite.launch import (  # noqa: E402
    GateError,
    bootstrap_from_receipt,
    verify_bootstrap,
)


def build_parser() -> argparse.ArgumentParser:
    # TUR-447 F4a (decision-109-workflow-native, role-worker-migration): the
    # worker-pass launcher is retired. The Claude Workflow subagent path is the
    # sole WORKER spawn mechanism, so octo-launch no longer prepares or runs a
    # worker pass. Only the persistent-session bootstrap surface remains, binding
    # the retained generic persistent receipt (Unit K).
    parser = argparse.ArgumentParser(description="Persistent-session bootstrap for the generic launch receipt")
    commands = parser.add_subparsers(dest="command", required=True)
    bootstrap = commands.add_parser("bootstrap", help="Bootstrap-verify an already-prepared persistent receipt only")
    bootstrap.add_argument("--receipt", type=Path, required=True)
    verify = commands.add_parser("verify", help="Verify a captured BOOTSTRAP_ACK")
    verify.add_argument("--receipt", type=Path, required=True)
    verify.add_argument("--ack", type=Path, required=True)
    return parser


def main() -> int:
    try:
        args = build_parser().parse_args()
        if args.command == "verify":
            acknowledgment = json.loads(args.ack.read_text())
            value = acknowledgment.get("BOOTSTRAP_ACK", acknowledgment)
            verified = verify_bootstrap(args.receipt, value)
            print(json.dumps({"ready": True, "provider_session_id": verified["provider_session_id"]}))
            return 0
        if args.command == "bootstrap":
            provider_session_id = bootstrap_from_receipt(args.receipt)
            print(json.dumps({"verified": True, "provider_session_id": provider_session_id}))
            return 0
        raise GateError(f"unknown command: {args.command}")
    except (
        GateError,
        OSError,
        ValueError,
        json.JSONDecodeError,
        subprocess.CalledProcessError,
        tomllib.TOMLDecodeError,
    ) as error:
        print(f"octo-launch: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
