#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import tomllib
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from octo_lite.runtime import (  # noqa: E402
    GateError,
    append_trace,
    admit_workspace,
    bind_pass_result,
    declare_successor_ready,
    exact_fingerprint,
    herdr_label,
    launch_revision,
    normalize_launch_access,
    record_acceptance,
    record_failure,
    safe_cleanup,
    initialize_stream,
    update_stream_brief,
    write_stream_status,
    transfer_owner,
    transition_linear,
    verdict_body,
)

SHAPING_VERDICT_MARKER = "<!-- octo-lite-verdict:shaping -->"


def load_toml(path: Path) -> dict:
    with path.open("rb") as handle:
        return tomllib.load(handle)


def run_json(argv: list[str]) -> dict:
    result = subprocess.run(argv, check=True, capture_output=True, text=True)
    return json.loads(result.stdout)


def linear_read(issue: str) -> dict:
    raw = run_json(["linear", "issue", "view", issue, "--json", "--no-download"])
    state = raw.get("state")
    normalized = dict(raw)
    normalized["state"] = state.get("name") if isinstance(state, dict) else state
    return {"issue": normalized, "fingerprint": exact_fingerprint(normalized)}


def write_status(path: Path, issue: dict, args) -> None:
    text = (
        f"Outcome: {args.outcome}\n"
        f"Gate: {args.gate}\n"
        f"Blocker: {args.blocker}\n"
        f"Next operator action: {args.next_action}\n"
        f"Issue: {issue['identifier']}\n"
        f"Linear state: {issue['state']}\n"
        f"Linear fingerprint: {exact_fingerprint(issue)}\n"
    )
    temporary = path.with_suffix(path.suffix + f".{os.getpid()}.tmp")
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary.write_text(text)
    os.replace(temporary, path)


def command_linear_read(args) -> dict:
    return linear_read(args.issue)


def _verify_transition_authority(args) -> None:
    if bool(args.stream) == bool(args.receipt):
        raise GateError("exactly one of --stream or --receipt required")
    if args.stream:
        stream_state = load_toml(Path(args.stream) / "stream.toml")
        if stream_state.get("child_session") != args.caller:
            raise GateError("caller is not the exact stream owner")
        if stream_state.get("child_role") != "orchestrator":
            raise GateError("caller is not the exact issue-orchestrator role")
        if stream_state.get("stream_id") != args.issue:
            raise GateError("stream_id does not match requested issue")
        return
    receipt = load_toml(Path(args.receipt))
    if receipt.get("bootstrap", {}).get("verified") is not True:
        raise GateError("caller receipt bootstrap not verified")
    if receipt.get("role", {}).get("name") != "orchestrator":
        raise GateError("caller is not the exact issue-orchestrator role")
    if receipt.get("issue", {}).get("identifier") != args.issue:
        raise GateError("caller receipt issue mismatch")
    if receipt.get("bootstrap", {}).get("provider_session_id") != args.caller:
        raise GateError("caller is not the exact receipt-bound session")


def _verify_shaped_transition_authority(args) -> dict:
    if args.stream or not args.receipt:
        raise GateError("Shaped transition requires exact receipt authority")
    receipt = load_toml(Path(args.receipt))
    if receipt.get("bootstrap", {}).get("verified") is not True:
        raise GateError("caller receipt bootstrap not verified")
    if receipt.get("role", {}).get("name") != "orchestrator":
        raise GateError("caller is not the exact issue-orchestrator role")
    if receipt.get("issue", {}).get("identifier") != args.issue:
        raise GateError("caller receipt issue mismatch")
    if receipt.get("bootstrap", {}).get("provider_session_id") != args.caller:
        raise GateError("caller is not the exact receipt-bound session")
    if receipt.get("purpose") != "shaping-review":
        raise GateError("caller receipt purpose is not shaping-review")
    if not isinstance(receipt.get("launch_revision"), str) or receipt["launch_revision"] != launch_revision(receipt):
        raise GateError("caller receipt launch revision mismatch")
    shaping = receipt.get("shaping")
    if not isinstance(shaping, dict) or not all(shaping.get(key) for key in ("repo", "pr", "head")):
        raise GateError("caller receipt shaping binding missing")
    return shaping


def _verify_exact_shaping_marker(repo: str, pr: object, expected_head: str, issue: str, fingerprint: str) -> None:
    current = run_json(["gh", "pr", "view", str(pr), "--repo", repo, "--json", "headRefOid,comments"])
    if current.get("headRefOid") != expected_head:
        raise GateError("shaping PR head mismatch")
    comments = current.get("comments")
    if not isinstance(comments, list):
        raise GateError("shaping verdict comments unreadable")
    matches = [
        item.get("body", "") for item in comments
        if isinstance(item, dict) and SHAPING_VERDICT_MARKER in item.get("body", "")
    ]
    if not matches:
        raise GateError("shaping verdict missing")
    if len(matches) > 1:
        raise GateError("shaping verdict duplicate")
    block = re.search(r"```toml\s*(.*?)\s*```", matches[0], re.DOTALL)
    if not block:
        raise GateError("shaping verdict unreadable")
    try:
        parsed = tomllib.loads(block.group(1))
    except tomllib.TOMLDecodeError as error:
        raise GateError("shaping verdict unreadable") from error
    if parsed.get("schema_version") != 1:
        raise GateError("shaping verdict schema mismatch")
    if parsed.get("review_type") != "shaping":
        raise GateError("shaping verdict wrong review type")
    if parsed.get("verdict") != "clear":
        raise GateError("shaping verdict not clear")
    if parsed.get("head") != expected_head:
        raise GateError("shaping verdict head mismatch")
    binding = f"linear:{issue}:{fingerprint}"
    bound_inputs = parsed.get("bound_inputs")
    if not isinstance(bound_inputs, list) or binding not in bound_inputs:
        raise GateError("shaping verdict binding mismatch")


def command_linear_transition(args) -> dict:
    allowed = {
        ("Todo", "In Progress"),
        ("In Progress", "Awaiting Accept"),
        ("Ideas", "Shaped"),
        ("Todo", "Shaped"),
    }
    if (args.expected, args.target) not in allowed:
        raise GateError("stream orchestrator transition not allowed")
    if args.target == "Shaped":
        shaping = _verify_shaped_transition_authority(args)
    else:
        shaping = None
        _verify_transition_authority(args)

    compare_cache: dict[str, dict] = {}

    def read():
        issue = linear_read(args.issue)["issue"]
        compare_cache["issue"] = issue
        return issue

    def mutate(target):
        if shaping is not None:
            current_issue = compare_cache["issue"]
            fingerprint = exact_fingerprint(current_issue)
            _verify_exact_shaping_marker(
                shaping["repo"], shaping["pr"], shaping["head"], args.issue, fingerprint
            )
        subprocess.run(
            ["linear", "issue", "update", args.issue, "--state", target],
            check=True,
        )

    def status(issue):
        write_status(Path(args.status), dict(issue), args)

    def notify(issue):
        if not args.parent:
            raise GateError("parent route required")
        message = f"{args.issue} entered {issue['state']}; status {Path(args.status).resolve()}"
        if args.parent == "operator":
            # A top-level notification resolves the current owner through operator-say
            # rather than a static route, so it always reaches the post-handoff owner.
            subprocess.run(["operator-say", message], check=True)
        else:
            subprocess.run(["herdr-say", args.parent, message], check=True)

    return transition_linear(
        args.issue,
        args.expected,
        args.target,
        Path(args.progress),
        read,
        mutate,
        status,
        notify,
    )


def command_verdict(args) -> dict:
    current = run_json(
        ["gh", "pr", "view", str(args.pr), "--repo", args.repo, "--json", "headRefOid"]
    )["headRefOid"]
    if current != args.head:
        raise GateError("PR HEAD mismatch")
    body = verdict_body(
        args.review_type,
        args.verdict,
        args.head,
        args.bound_input,
        args.finding,
        args.receipt,
        args.conversation_log_reference,
        args.conversation_cutoff,
    )
    marker = f"<!-- octo-lite-verdict:{args.review_type} -->"
    comments = run_json(
        ["gh", "api", f"repos/{args.repo}/issues/{args.pr}/comments", "--paginate"]
    )
    existing = next((item for item in comments if marker in item.get("body", "")), None)
    if existing:
        published = run_json(
            [
                "gh", "api", "--method", "PATCH",
                f"repos/{args.repo}/issues/comments/{existing['id']}",
                "-f", f"body={body}",
            ]
        )
    else:
        published = run_json(
            [
                "gh", "api", "--method", "POST",
                f"repos/{args.repo}/issues/{args.pr}/comments",
                "-f", f"body={body}",
            ]
        )
    readback = run_json(
        ["gh", "api", f"repos/{args.repo}/issues/comments/{published['id']}"]
    )
    if readback.get("body") != body:
        raise GateError("verdict comment readback mismatch")
    return {"url": readback["html_url"], "head": args.head, "verdict": args.verdict}


def command_owner(args) -> dict:
    handoff = Path(args.handoff)
    if not handoff.is_file():
        raise GateError("immutable handoff missing")
    return transfer_owner(
        Path(args.owner_file),
        args.expected_owner,
        args.expected_route,
        args.expected_revision,
        args.new_owner,
        args.new_route,
        args.revision,
        str(Path(args.control_dir).resolve()),
        caller=args.caller,
        handoff=handoff,
        successor_readiness_path=Path(args.successor_readiness),
    )


def command_successor_ready(args) -> dict:
    return declare_successor_ready(
        Path(args.path), caller=args.caller, session_id=args.session_id, handoff_revision=args.handoff_revision,
    )


def command_accept(args) -> dict:
    return record_acceptance(
        Path(args.path),
        Path(args.owner_file),
        caller=args.caller,
        issue=args.issue,
        pr=args.pr,
        head=args.head,
        verdict_reference=args.verdict_reference,
        decision=args.decision,
    )


def command_trace(args) -> dict:
    event = json.loads(Path(args.event).read_text())
    written = append_trace(Path(args.trace), Path(args.status), event)
    return {"written": written, "degraded": not written}


def command_access(args) -> dict:
    values = {
        "execution_location": args.execution_location,
        "operator_loopback_access": args.operator_loopback_access,
        "review_delivery": args.review_delivery,
    }
    return normalize_launch_access({key: value for key, value in values.items() if value is not None})


def command_failure(args) -> dict:
    return record_failure(
        args.attempt,
        args.error,
        args.category,
        args.useful_work,
        args.owner,
        args.next_action,
    )


def command_label(args) -> dict:
    return {
        "label": herdr_label(
            kind=args.kind,
            issue=args.issue,
            pr=args.pr,
            outcome=args.outcome,
            direct=args.direct,
        )
    }


def command_stream_init(args) -> dict:
    return initialize_stream(
        Path(args.path),
        stream_id=args.stream_id,
        parent_session=args.parent,
        child_session=args.child,
        child_role=args.child_role,
        caller=args.caller,
        brief=Path(args.brief_file).read_text(),
    )


def command_stream_brief(args) -> dict:
    return update_stream_brief(
        Path(args.path),
        caller=args.caller,
        expected_revision=args.expected_revision,
        brief=Path(args.brief_file).read_text(),
    )


def command_stream_status(args) -> dict:
    path = Path(args.path)
    state = write_stream_status(
        path,
        caller=args.caller,
        expected_revision=args.expected_revision,
        outcome=args.outcome,
        gate=args.gate,
        blocker=args.blocker,
        next_operator_action=args.next_action,
    )
    parent = state["parent_session"]
    message = f"{state['stream_id']} status revision {state['status_revision']}"
    artifact = str((path / "status.md").resolve())
    if parent == "operator":
        # A top-level notification resolves the current owner through operator-say
        # rather than a static route, so it always reaches the post-handoff owner.
        result = subprocess.run(
            ["operator-say", "--kind", "info", "--artifact", artifact, message],
            check=False,
        )
    else:
        result = subprocess.run(
            ["herdr-say", "--kind", "info", "--artifact", artifact, parent, message],
            check=False,
        )
    if result.returncode not in {0, 75}:
        raise GateError("parent notification failed")
    state["notification"] = "queued" if result.returncode == 75 else "pending"
    return state


def command_result_bind(args) -> dict:
    result = json.loads(Path(args.result).read_text())
    binding = bind_pass_result(Path(args.receipt), args.role, result)
    return {"binding": binding}


def command_workspace_admit(args) -> dict:
    root = Path(args.worktree_root)
    target = Path(args.worktree)
    admitted = admit_workspace(
        target,
        root,
        disk_free_bytes=shutil.disk_usage(root).free,
        minimum_free_bytes=args.minimum_free_bytes,
        conflicts=args.conflict,
        provider_overloaded=args.provider_overloaded,
    )
    return {"admitted": True, "worktree": str(admitted)}


def command_workspace_cleanup(args) -> dict:
    control = Path(args.control_repo)

    def remove(worktree: Path) -> None:
        subprocess.run(["git", "-C", str(control), "worktree", "remove", str(worktree)], check=True)

    safe_cleanup(
        Path(args.worktree),
        worktree_root=Path(args.worktree_root),
        control_repo=control,
        handoff=Path(args.handoff),
        expected_head=args.expected_head,
        remote_ref=args.remote_ref,
        remove=remove,
    )
    return {"removed": True, "worktree": str(Path(args.worktree).resolve())}


def parser() -> argparse.ArgumentParser:
    root = argparse.ArgumentParser(description="Small foreground octo-lite gates")
    sub = root.add_subparsers(dest="command", required=True)

    read = sub.add_parser("linear-read")
    read.add_argument("issue")
    read.set_defaults(run=command_linear_read)

    transition = sub.add_parser("linear-transition")
    transition.add_argument("issue")
    transition.add_argument("--expected", required=True)
    transition.add_argument("--target", required=True)
    transition.add_argument("--progress", required=True)
    transition.add_argument("--status", required=True)
    transition.add_argument("--parent", required=True)
    transition.add_argument("--outcome", required=True)
    transition.add_argument("--gate", required=True)
    transition.add_argument("--blocker", default="none")
    transition.add_argument("--next-action", default="none")
    transition.add_argument("--caller", required=True)
    transition.add_argument("--stream")
    transition.add_argument("--receipt")
    transition.set_defaults(run=command_linear_transition)

    verdict = sub.add_parser("verdict-publish")
    verdict.add_argument("--repo", required=True)
    verdict.add_argument("--pr", type=int, required=True)
    verdict.add_argument("--review-type", choices=["shaping", "code"], required=True)
    verdict.add_argument("--verdict", choices=["clear", "blocking"], required=True)
    verdict.add_argument("--head", required=True)
    verdict.add_argument("--receipt", required=True)
    verdict.add_argument("--bound-input", action="append", default=[])
    verdict.add_argument("--finding", action="append", default=[])
    verdict.add_argument("--conversation-log-reference", action="append", default=[])
    verdict.add_argument("--conversation-cutoff", default="")
    verdict.set_defaults(run=command_verdict)

    owner = sub.add_parser("owner-transfer")
    owner.add_argument("--owner-file", required=True)
    owner.add_argument("--expected-owner", required=True)
    owner.add_argument("--expected-route", required=True)
    owner.add_argument("--expected-revision", type=int, required=True)
    owner.add_argument("--caller", required=True)
    owner.add_argument("--new-owner", required=True)
    owner.add_argument("--new-route", required=True)
    owner.add_argument("--revision", type=int, required=True)
    owner.add_argument("--control-dir", required=True)
    owner.add_argument("--handoff", required=True)
    owner.add_argument("--successor-readiness", required=True)
    owner.set_defaults(run=command_owner)

    successor_ready = sub.add_parser("successor-ready")
    successor_ready.add_argument("--path", required=True)
    successor_ready.add_argument("--caller", required=True)
    successor_ready.add_argument("--session-id", required=True)
    successor_ready.add_argument("--handoff-revision", type=int, required=True)
    successor_ready.set_defaults(run=command_successor_ready)

    accept = sub.add_parser("accept")
    accept.add_argument("--path", required=True)
    accept.add_argument("--owner-file", required=True)
    accept.add_argument("--caller", required=True)
    accept.add_argument("--issue", required=True)
    accept.add_argument("--pr", required=True)
    accept.add_argument("--head", required=True)
    accept.add_argument("--verdict-reference", required=True)
    accept.add_argument("--decision", choices=["accept", "reject"], required=True)
    accept.set_defaults(run=command_accept)

    trace = sub.add_parser("trace-append")
    trace.add_argument("--trace", required=True)
    trace.add_argument("--status", required=True)
    trace.add_argument("--event", required=True)
    trace.set_defaults(run=command_trace)

    access = sub.add_parser("launch-access")
    access.add_argument("--execution-location")
    access.add_argument("--operator-loopback-access", action="store_true", default=None)
    access.add_argument("--review-delivery")
    access.set_defaults(run=command_access)

    failure = sub.add_parser("failure-record")
    failure.add_argument("--attempt", type=int, required=True)
    failure.add_argument("--error", required=True)
    failure.add_argument("--category", required=True)
    failure.add_argument("--useful-work", default="")
    failure.add_argument("--owner", required=True)
    failure.add_argument("--next-action", required=True)
    failure.set_defaults(run=command_failure)

    label = sub.add_parser("herdr-label")
    label.add_argument("--kind", choices=["operator", "epic", "issue"], required=True)
    label.add_argument("--issue", type=int)
    label.add_argument("--pr", type=int)
    label.add_argument("--outcome")
    label.add_argument("--direct", action="store_true")
    label.set_defaults(run=command_label)

    stream_init = sub.add_parser("stream-init")
    stream_init.add_argument("--path", required=True)
    stream_init.add_argument("--stream-id", required=True)
    stream_init.add_argument("--parent", required=True)
    stream_init.add_argument("--child", required=True)
    stream_init.add_argument("--child-role", required=True)
    stream_init.add_argument("--caller", required=True)
    stream_init.add_argument("--brief-file", required=True)
    stream_init.set_defaults(run=command_stream_init)

    stream_brief = sub.add_parser("stream-brief")
    stream_brief.add_argument("--path", required=True)
    stream_brief.add_argument("--caller", required=True)
    stream_brief.add_argument("--expected-revision", type=int, required=True)
    stream_brief.add_argument("--brief-file", required=True)
    stream_brief.set_defaults(run=command_stream_brief)

    stream_status = sub.add_parser("stream-status")
    stream_status.add_argument("--path", required=True)
    stream_status.add_argument("--caller", required=True)
    stream_status.add_argument("--expected-revision", type=int, required=True)
    stream_status.add_argument("--outcome", required=True)
    stream_status.add_argument("--gate", required=True)
    stream_status.add_argument("--blocker", default="none")
    stream_status.add_argument("--next-action", default="none")
    stream_status.set_defaults(run=command_stream_status)

    result_bind = sub.add_parser("result-bind")
    result_bind.add_argument("--receipt", required=True)
    result_bind.add_argument("--role", required=True)
    result_bind.add_argument("--result", required=True)
    result_bind.set_defaults(run=command_result_bind)

    admission = sub.add_parser("workspace-admit")
    admission.add_argument("--worktree", required=True)
    admission.add_argument("--worktree-root", required=True)
    admission.add_argument("--minimum-free-bytes", type=int, required=True)
    admission.add_argument("--conflict", action="append", default=[])
    admission.add_argument("--provider-overloaded", action="store_true")
    admission.set_defaults(run=command_workspace_admit)

    cleanup = sub.add_parser("workspace-cleanup")
    cleanup.add_argument("--worktree", required=True)
    cleanup.add_argument("--worktree-root", required=True)
    cleanup.add_argument("--control-repo", required=True)
    cleanup.add_argument("--handoff", required=True)
    cleanup.add_argument("--expected-head", required=True)
    cleanup.add_argument("--remote-ref", required=True)
    cleanup.set_defaults(run=command_workspace_cleanup)
    return root


def main() -> int:
    try:
        args = parser().parse_args()
        print(json.dumps(args.run(args), sort_keys=True, ensure_ascii=False))
        return 0
    except (GateError, subprocess.CalledProcessError, json.JSONDecodeError, OSError) as error:
        print(f"octo-control: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
