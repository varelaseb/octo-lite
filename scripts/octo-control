            direct=args.direct,
        )
    }


def command_stream_init(args) -> dict:
    return initialize_stream(
        Path(args.path),
        stream_id=args.stream_id,
        parent_session=args.parent,
        child_session=args.child,
        child_role=args.child_role,
        caller=args.caller,
        brief=Path(args.brief_file).read_text(),
    )


def command_stream_brief(args) -> dict:
    return update_stream_brief(
        Path(args.path),
        caller=args.caller,
        expected_revision=args.expected_revision,
        brief=Path(args.brief_file).read_text(),
    )


def command_stream_status(args) -> dict:
    path = Path(args.path)
    state = write_stream_status(
        path,
        caller=args.caller,
        expected_revision=args.expected_revision,
        outcome=args.outcome,
        gate=args.gate,
        blocker=args.blocker,
        next_operator_action=args.next_action,
    )
    parent = state["parent_session"]
    message = f"{state['stream_id']} status revision {state['status_revision']}"
    artifact = str((path / "status.md").resolve())
    if parent == "operator":
        # A top-level notification resolves the current owner through operator-say
        # rather than a static route, so it always reaches the post-handoff owner.
        result = subprocess.run(
            ["operator-say", "--kind", "info", "--artifact", artifact, message],
            check=False,
        )
    else:
        result = subprocess.run(
            ["herdr-say", "--kind", "info", "--artifact", artifact, parent, message],
            check=False,
        )
    if result.returncode not in {0, 75}:
        raise GateError("parent notification failed")
    state["notification"] = "queued" if result.returncode == 75 else "pending"
    return state


def command_result_bind(args) -> dict:
    result = json.loads(Path(args.result).read_text())
    binding = bind_pass_result(Path(args.receipt), args.role, result)
    return {"binding": binding}


# Unit L operator-intent record (delivery-lifecycle shaping-operator-approval
# and shaping-operator-approval-binding, operator-control
# supervision-operator-gate-no-hashes and supervision-default-action,
# role-runtime launch-shaping-authority): prior explicit operator intent is
# recorded machine-checkably, the tool itself stamps the current exact head at
# action time, and Unit J consumes exactly this record.


def _canonical_slug(slug: str) -> str:
    # Canonical owner/repo identity for cross-surface binding: strip a git host
    # prefix, a trailing .git, and case, so the verdict repo, the intent record
    # repo, and the CLI repo slug all normalize to one comparable identity even
    # if a caller passes a full remote URL. It is deliberately NOT a filesystem
    # path: git -C uses the separate --repo local path, gh uses this slug.
    value = slug.strip()
    if not value:
        raise GateError("repo slug empty")
    for prefix in ("git@github.com:", "https://github.com/", "http://github.com/", "ssh://git@github.com/"):
        if value.startswith(prefix):
            value = value[len(prefix):]
            break
    if value.endswith(".git"):
        value = value[: -len(".git")]
    value = value.strip("/").lower()
    if not re.fullmatch(r"[0-9a-z._-]+/[0-9a-z._-]+", value):
        raise GateError(f"repo slug not a canonical owner/repo identity: {slug}")
    return value


def _current_repo_head(repo: str) -> str:
    result = subprocess.run(
        ["git", "-C", repo, "rev-parse", "HEAD"],
        check=True, capture_output=True, text=True,
    )
    head = result.stdout.strip()
    if not re.fullmatch(r"[0-9a-f]{40}", head):
        raise GateError("repo head unreadable")
    return head


_INTENT_SURFACE_MARKER = "<!-- octo-lite-intent-record -->"


def _intent_surface_body(*, repo: str, pr: object, head: str, intent_ref: str, recorded_at: str) -> str:
    # The command-published PR/status surface body. It binds the exact repo
    # slug, PR, head, intent reference, and stamp, so a hand-authored local
    # TOML cannot forge the matching live publication: the record carries a
    # digest of exactly this body and Unit J re-reads the live surface to match
    # it. Body equality is necessary but not sufficient: the record also binds
    # the exact live comment id and the trusted publisher author identity, so a
    # matching body posted by any other identity is rejected.
    payload = {
        "schema_version": 1,
        "repo": repo,
        "pr": pr,
        "head": head,
        "intent_ref": intent_ref,
        "recorded_at": recorded_at,
    }
    return _INTENT_SURFACE_MARKER + "\n```json\n" + json.dumps(payload, sort_keys=True) + "\n```\n"


def _comment_author_login(comment: dict) -> str | None:
    user = comment.get("user")
    if isinstance(user, dict):
        login = user.get("login")
        if isinstance(login, str) and login.strip():
            return login
    return None


def _surface_digest(body: str) -> str:
    return hashlib.sha256(body.encode("utf-8")).hexdigest()


def _read_intent_record(path: Path) -> dict:
    if not path.is_file():
        raise GateError("intent record missing")
    try:
        record = load_toml(path)
    except (OSError, tomllib.TOMLDecodeError) as error:
        raise GateError("intent record unreadable") from error
    if record.get("schema_version") != 1:
        raise GateError("intent record schema mismatch")
    for key in ("intent_ref", "head", "recorded_at", "repo", "surface_sha256", "publisher"):
        value = record.get(key)
        if not isinstance(value, str) or not value.strip():
            raise GateError(f"intent record {key} missing")
    if not isinstance(record.get("pr"), int):
        raise GateError("intent record pr missing")
    if not isinstance(record.get("comment_id"), int):
        raise GateError("intent record comment_id missing")
    return record


def _fetch_intent_comment(repo_slug: str, comment_id: int) -> dict | None:
    try:
        comment = run_json(
            ["gh", "api", f"repos/{repo_slug}/issues/comments/{comment_id}"]
        )
    except subprocess.CalledProcessError:
        return None
    if not isinstance(comment, dict):
        return None
    return comment


def _derive_trusted_publisher() -> str:
    # F5-r2 fix 1 (delivery-tdd-trusted-command-source discipline applied to the
    # operator-intent surface): the trusted publisher is DERIVED from a
    # non-caller source, the authenticated gh actor of the control identity that
    # actually posts the intent surface, NEVER a caller-supplied flag. A caller
    # cannot self-authorize by naming a forged identity because it cannot forge
    # the authenticated `gh api user` login of the control CLI. This is the same
    # identity command_intent_record stamps as `publisher` at publication time.
    try:
        user = run_json(["gh", "api", "user"])
    except subprocess.CalledProcessError as error:
        raise GateError("trusted publisher underivable: gh authenticated identity unavailable") from error
    login = user.get("login") if isinstance(user, dict) else None
    if not isinstance(login, str) or not login.strip():
        raise GateError("trusted publisher underivable: gh authenticated identity has no login")
    return login


def _verify_intent_record(
    path: Path, repo_local: str, repo_slug: str, caller_publisher: str | None = None
) -> dict:
    record = _read_intent_record(path)
    head = record["head"]
    if not re.fullmatch(r"[0-9a-f]{40}", head):
        raise GateError("intent record head malformed")
    # Repo split + canonical bind: the record binds the exact canonical repo
    # slug; --repo is the separate local path used only for the git head check.
    if _canonical_slug(record["repo"]) != _canonical_slug(repo_slug):
        raise GateError("intent record repo mismatch with CLI repo slug")
    probe = subprocess.run(
        ["git", "-C", repo_local, "cat-file", "-e", f"{head}^{{commit}}"],
        capture_output=True, text=True,
    )
    if probe.returncode != 0:
        raise GateError("intent record head unknown to repo")
    # Self-consistency: the surface digest must be the digest of exactly this
    # record's own fields, so a digest borrowed from an unrelated surface fails
    # before any live fetch.
    expected_body = _intent_surface_body(
        repo=record["repo"], pr=record["pr"], head=head,
        intent_ref=record["intent_ref"], recorded_at=record["recorded_at"],
    )
    if record["surface_sha256"] != _surface_digest(expected_body):
        raise GateError("intent record surface digest does not bind its own fields")
    # F5-r2 fix 1: the trusted publisher is DERIVED here from the authenticated
    # gh actor of the control identity, a NON-caller source, only after the
    # local record self-checks pass (so a missing/malformed record still fails
    # before any gh call). A caller-supplied value is never the source; when
    # present it is only a misconfiguration cross-check and must equal the
    # derived identity, else the pipeline is mis-provisioned and fails closed.
    trusted_publisher = _derive_trusted_publisher()
    if caller_publisher is not None and caller_publisher.strip() and caller_publisher != trusted_publisher:
        raise GateError(
            "caller-supplied trusted publisher differs from the derived control identity: "
            "trusted publisher is derived, not caller-selected"
        )
    # Unforgeable publication identity: fetch the EXACT bound comment id off the
    # live PR surface and require (a) it actually exists, (b) its body digest
    # equals the record digest, and (c) its author login equals the trusted
    # command-publisher identity. gh api returns each comment's author identity,
    # so a fabricated TOML plus a self-posted comment under any other login is
    # rejected: only a comment the trusted publisher actually posted, bound by
    # exact id, carries authority. A local record with no such comment fails.
    comment = _fetch_intent_comment(repo_slug, record["comment_id"])
    if comment is None:
        raise GateError("intent record has no command-published surface: forged record rejected")
    if _INTENT_SURFACE_MARKER not in (comment.get("body") or ""):
        raise GateError("intent record bound comment is not an operator-intent surface")
    if _surface_digest(comment["body"]) != record["surface_sha256"]:
        raise GateError("intent record surface digest mismatch with live publication")
    author = _comment_author_login(comment)
    if author != trusted_publisher:
        raise GateError(
            "intent record surface not published by the trusted command identity: forged record rejected"
        )
    if record["publisher"] != trusted_publisher:
        raise GateError("intent record publisher does not match the trusted command identity")
    return record


def command_intent_record(args) -> dict:
    path = Path(args.stream_dir) / "intent-record.toml"
    # Repo split: --repo is the LOCAL PATH for git -C, --repo-slug is the
    # canonical owner/repo gh identity. A single value cannot serve both.
    repo_slug = _canonical_slug(args.repo_slug)
    if args.verify:
        # --trusted-publisher is no longer required and is never the authority
        # source: it is derived from the authenticated control identity. A
        # supplied value is only a cross-check against that derived identity.
        record = _verify_intent_record(path, args.repo, repo_slug, args.trusted_publisher)
        return {
            "record": str(path.resolve()),
            "head": record["head"],
            "intent_ref": record["intent_ref"],
            "recorded_at": record["recorded_at"],
            "repo": record["repo"],
            "pr": record["pr"],
            "comment_id": record["comment_id"],
            "publisher": record["publisher"],
            "verified": True,
        }
    if not isinstance(args.intent_ref, str) or not args.intent_ref.strip():
        raise GateError("intent-ref required nonempty")
    if not isinstance(args.pr, int):
        raise GateError("intent record requires --pr for surface publication")
    # Compare: the tool captures the current exact head itself at action time;
    # no supplied head is ever accepted (no --head flag exists). The head comes
    # from the LOCAL repo path.
    head = _current_repo_head(args.repo)
    recorded_at = datetime.now(timezone.utc).isoformat()
    surface_body = _intent_surface_body(
        repo=repo_slug, pr=args.pr, head=head,
        intent_ref=args.intent_ref, recorded_at=recorded_at,
    )
    surface_sha256 = _surface_digest(surface_body)
    # Publish the binding to the PR/status surface, then read it back off the
    # live surface before persisting the record: a failed readback aborts. The
    # readback captures the actual command-publisher author identity and the
    # exact comment id, so the persisted record binds an unforgeable publication.
    published = _publish_intent_surface(repo_slug, args.pr, surface_body)
    readback = run_json(
        ["gh", "api", f"repos/{repo_slug}/issues/comments/{published['id']}"]
    )
    if readback.get("body") != surface_body:
        raise GateError("intent record surface readback mismatch")
    comment_id = readback.get("id")
    if not isinstance(comment_id, int):
        raise GateError("intent record surface readback missing comment id")
    publisher = _comment_author_login(readback)
    if publisher is None:
        raise GateError("intent record surface readback missing publisher identity")
    text = (
        "schema_version = 1\n"
        f"intent_ref = {json.dumps(args.intent_ref)}\n"
        f'head = "{head}"\n'
        f'recorded_at = "{recorded_at}"\n'
        f"repo = {json.dumps(repo_slug)}\n"
        f"pr = {args.pr}\n"
        f'surface_sha256 = "{surface_sha256}"\n'
        f"comment_id = {comment_id}\n"
        f"publisher = {json.dumps(publisher)}\n"
    )
    # Act: whole-record atomic replace; a partial or corrupt existing record
    # is overwritten, never appended.
    _atomic_write_text(path, text)
    # Readback: verify persisted content before reporting success.
    record = _read_intent_record(path)
    if (
        record["intent_ref"] != args.intent_ref
        or record["head"] != head
        or record["recorded_at"] != recorded_at
        or record["repo"] != repo_slug
        or record["pr"] != args.pr
        or record["surface_sha256"] != surface_sha256
        or record["comment_id"] != comment_id
        or record["publisher"] != publisher
    ):
        raise GateError("intent record readback mismatch")
    return {
        "record": str(path.resolve()),
        "head": head,
        "intent_ref": args.intent_ref,
        "recorded_at": recorded_at,
        "repo": repo_slug,
        "pr": args.pr,
        "comment_id": comment_id,
        "publisher": publisher,
        "surface_url": readback.get("html_url"),
    }


def _publish_intent_surface(repo: str, pr: object, body: str) -> dict:
    comments = run_json(
        ["gh", "api", f"repos/{repo}/issues/{pr}/comments", "--paginate"]
    )
    existing = next(
        (item for item in comments if _INTENT_SURFACE_MARKER in item.get("body", "")),
        None,
    )
    if existing:
        return run_json(
            [
                "gh", "api", "--method", "PATCH",
                f"repos/{repo}/issues/comments/{existing['id']}",
                "-f", f"body={body}",
            ]
        )
    return run_json(
        [
            "gh", "api", "--method", "POST",
            f"repos/{repo}/issues/{pr}/comments",
            "-f", f"body={body}",
        ]
    )


def command_workspace_admit(args) -> dict:
    # gh#8 host-provisioned isolated worktree (workspace-admission-provisions):
    # supplying all five provisioning flags (control-repo/lane/branch/
    # starting-commit/repo-slug) admits then PROVISIONS the exclusive per-lane
    # worktree; stdout then carries the frozen out-of-tree record. Omitting
    # every provisioning flag preserves the prior admit-only behavior (disk/
    # conflict/containment guard only, no worktree created), so an existing
    # admit-only caller is never silently broken by this additive
    # subcommand-family (code-review finding 9).
    # Adoption backfill: adopt an EXISTING pre-fix hand-created worktree that
    # carries no lane record. --starting-commit is optional (the head is derived
    # from the live worktree) and a mid-delivery dirty tree is tolerated; the
    # worktree is never touched, only the out-of-tree record is written.
    if getattr(args, "adopt_existing", False):
        required = {
            "control_repo": args.control_repo,
            "lane": args.lane,
            "branch": args.branch,
            "repo_slug": args.repo_slug,
        }
        missing = sorted(name for name, value in required.items() if value is None)
        if missing:
            flags = ", ".join(f"--{name.replace('_', '-')}" for name in missing)
            raise GateError(
                "workspace-admit --adopt-existing requires --control-repo, --lane, "
                f"--branch, and --repo-slug; missing: {flags}"
            )
        provision = provision_lane_worktree(
            control_repo=Path(args.control_repo),
            worktree_root=Path(args.worktree_root),
            worktree=Path(args.worktree),
            lane=args.lane,
            branch=args.branch,
            head=args.starting_commit,
            repo_slug=args.repo_slug,
            octo_control_repo=Path(args.octo_control_repo) if args.octo_control_repo else None,
            minimum_free_bytes=args.minimum_free_bytes,
            conflicts=args.conflict,
            provider_overloaded=args.provider_overloaded,
            adopt_existing=True,
        )
        return {
            "admitted": True,
            "adopted": True,
            "worktree": provision.record["worktree"],
            "record_path": str(provision.record_path),
            "install_check_owner_route": provision.install_check_owner_route,
            "record": provision.record,
        }
    provisioning_flags = {
        "control_repo": args.control_repo,
        "lane": args.lane,
        "branch": args.branch,
        "starting_commit": args.starting_commit,
        "repo_slug": args.repo_slug,
    }
    provided = {name: value for name, value in provisioning_flags.items() if value is not None}
    if not provided:
        root = Path(args.worktree_root)
        target = Path(args.worktree)
        admitted = admit_workspace(
            target,
            root,
            disk_free_bytes=shutil.disk_usage(root).free,
            minimum_free_bytes=args.minimum_free_bytes,
            conflicts=args.conflict,
            provider_overloaded=args.provider_overloaded,
        )
        return {"admitted": True, "worktree": str(admitted)}
    if len(provided) != len(provisioning_flags):
        missing = sorted(set(provisioning_flags) - set(provided))
        flags = ", ".join(f"--{name.replace('_', '-')}" for name in missing)
        raise GateError(
            "workspace-admit provisioning requires --control-repo, --lane, --branch, "
            f"--starting-commit, and --repo-slug together; missing: {flags}"
        )
    provision = provision_lane_worktree(
        control_repo=Path(args.control_repo),
        worktree_root=Path(args.worktree_root),
        worktree=Path(args.worktree),
        lane=args.lane,
        branch=args.branch,
        head=args.starting_commit,
        repo_slug=args.repo_slug,
        octo_control_repo=Path(args.octo_control_repo) if args.octo_control_repo else None,
        minimum_free_bytes=args.minimum_free_bytes,
        conflicts=args.conflict,
        provider_overloaded=args.provider_overloaded,
    )
    return {
        "admitted": True,
        "worktree": provision.record["worktree"],
        "record_path": str(provision.record_path),
        # code-review finding 8: SURFACE the drift owner-routing signal rather
        # than discarding it, so a genuine install drift is always routed.
        "install_check_owner_route": provision.install_check_owner_route,
        "record": provision.record,
    }


def command_workspace_cleanup(args) -> dict:
    control = Path(args.control_repo)

    def remove(worktree: Path) -> None:
        subprocess.run(["git", "-C", str(control), "worktree", "remove", str(worktree)], check=True)

    safe_cleanup(
        Path(args.worktree),
        worktree_root=Path(args.worktree_root),
        control_repo=control,
        handoff=Path(args.handoff),
        expected_head=args.expected_head,
        remote_ref=args.remote_ref,
        remove=remove,
    )
    return {"removed": True, "worktree": str(Path(args.worktree).resolve())}


def parser() -> argparse.ArgumentParser:
    root = argparse.ArgumentParser(description="Small foreground octo-lite gates")
    sub = root.add_subparsers(dest="command", required=True)

    read = sub.add_parser("linear-read")
    read.add_argument("issue")
    read.set_defaults(run=command_linear_read)

    transition = sub.add_parser("linear-transition")
    transition.add_argument("issue")
    transition.add_argument("--expected", required=True)
    transition.add_argument("--target", required=True)
    transition.add_argument("--progress", required=True)
    transition.add_argument("--status", required=True)
    transition.add_argument("--parent", required=True)
    transition.add_argument("--outcome", required=True)
    transition.add_argument("--gate", required=True)
    transition.add_argument("--blocker", default="none")
    transition.add_argument("--next-action", default="none")
    transition.add_argument("--caller", required=True)
    transition.add_argument("--stream")
    transition.add_argument("--receipt")
    transition.add_argument("--verdict-journal")
    transition.add_argument("--repo", help="local repo path for git -C head checks")
    transition.add_argument("--repo-slug", help="canonical owner/repo slug for gh api / gh pr view")
    transition.add_argument("--trusted-publisher", help="trusted command-publisher comment author identity")
    transition.set_defaults(run=command_linear_transition)

    verdict = sub.add_parser("verdict-publish")
    verdict.add_argument("--repo", required=True, help="local repo path")
    verdict.add_argument("--repo-slug", required=True, help="canonical owner/repo slug for gh api / gh pr view")
    verdict.add_argument("--pr", type=int, required=True)
    verdict.add_argument("--review-type", choices=["shaping", "code"], required=True)
    verdict.add_argument("--verdict", choices=["clear", "blocking"], required=True)
    verdict.add_argument("--head", required=True)
    verdict.add_argument("--receipt", required=True)
    verdict.add_argument("--bound-input", action="append", default=[])
    verdict.add_argument("--finding", action="append", default=[])
    verdict.add_argument("--conversation-log-reference", action="append", default=[])
    verdict.add_argument("--conversation-cutoff", default="")
    verdict.set_defaults(run=command_verdict)

    owner = sub.add_parser("owner-transfer")
    owner.add_argument("--owner-file", required=True)
    owner.add_argument("--expected-owner", required=True)
    owner.add_argument("--expected-route", required=True)
    owner.add_argument("--expected-revision", type=int, required=True)
    owner.add_argument("--caller", required=True)
    owner.add_argument("--new-owner", required=True)
    owner.add_argument("--new-route", required=True)
    owner.add_argument("--revision", type=int, required=True)
    owner.add_argument("--control-dir", required=True)
    owner.add_argument("--handoff", required=True)
    owner.add_argument("--successor-readiness", required=True)
    owner.set_defaults(run=command_owner)

    successor_ready = sub.add_parser("successor-ready")
    successor_ready.add_argument("--path", required=True)
    successor_ready.add_argument("--caller", required=True)
    successor_ready.add_argument("--session-id", required=True)
    successor_ready.add_argument("--handoff-revision", type=int, required=True)
    successor_ready.set_defaults(run=command_successor_ready)

    accept = sub.add_parser("accept")
    accept.add_argument("--path", required=True)
    accept.add_argument("--owner-file", required=True)
    accept.add_argument("--caller", required=True)
    accept.add_argument("--issue", required=True)
    accept.add_argument("--pr", required=True)
    accept.add_argument("--head", required=True)
    accept.add_argument("--verdict-reference", required=True)
    accept.add_argument("--decision", choices=["accept", "reject"], required=True)
    accept.set_defaults(run=command_accept)

    trace = sub.add_parser("trace-append")
    trace.add_argument("--trace", required=True)
    trace.add_argument("--status", required=True)
    trace.add_argument("--event", required=True)
    trace.set_defaults(run=command_trace)

    access = sub.add_parser("launch-access")
    access.add_argument("--execution-location")
    access.add_argument("--operator-loopback-access", action="store_true", default=None)
    access.add_argument("--review-delivery")
    access.set_defaults(run=command_access)

    failure = sub.add_parser("failure-record")
    failure.add_argument("--attempt", type=int, required=True)
    failure.add_argument("--error", required=True)
    failure.add_argument("--category", required=True)
    failure.add_argument("--useful-work", default="")
    failure.add_argument("--owner", required=True)
    failure.add_argument("--next-action", required=True)
    failure.set_defaults(run=command_failure)

    label = sub.add_parser("herdr-label")
    label.add_argument("--kind", choices=["operator", "epic", "issue"], required=True)
    label.add_argument("--issue", type=int)
    label.add_argument("--pr", type=int)
    label.add_argument("--outcome")
    label.add_argument("--direct", action="store_true")
    label.set_defaults(run=command_label)

    stream_init = sub.add_parser("stream-init")
    stream_init.add_argument("--path", required=True)
    stream_init.add_argument("--stream-id", required=True)
    stream_init.add_argument("--parent", required=True)
    stream_init.add_argument("--child", required=True)
    stream_init.add_argument("--child-role", required=True)
    stream_init.add_argument("--caller", required=True)
    stream_init.add_argument("--brief-file", required=True)
    stream_init.set_defaults(run=command_stream_init)

    stream_brief = sub.add_parser("stream-brief")
    stream_brief.add_argument("--path", required=True)
    stream_brief.add_argument("--caller", required=True)
    stream_brief.add_argument("--expected-revision", type=int, required=True)
    stream_brief.add_argument("--brief-file", required=True)
    stream_brief.set_defaults(run=command_stream_brief)

    stream_status = sub.add_parser("stream-status")
    stream_status.add_argument("--path", required=True)
    stream_status.add_argument("--caller", required=True)
    stream_status.add_argument("--expected-revision", type=int, required=True)
    stream_status.add_argument("--outcome", required=True)
    stream_status.add_argument("--gate", required=True)
    stream_status.add_argument("--blocker", default="none")
    stream_status.add_argument("--next-action", default="none")
    stream_status.set_defaults(run=command_stream_status)

    result_bind = sub.add_parser("result-bind")
    result_bind.add_argument("--receipt", required=True)
    result_bind.add_argument("--role", required=True)
    result_bind.add_argument("--result", required=True)
    result_bind.set_defaults(run=command_result_bind)

    intent = sub.add_parser("intent-record")
    intent.add_argument("--stream-dir", required=True)
    intent.add_argument("--intent-ref")
    intent.add_argument("--repo", required=True, help="local repo path for git -C head checks")
    intent.add_argument("--repo-slug", required=True, help="canonical owner/repo slug for gh api")
    intent.add_argument("--pr", type=int)
    intent.add_argument("--verify", action="store_true")
    intent.add_argument("--trusted-publisher", help="trusted command-publisher comment author identity")
    intent.set_defaults(run=command_intent_record)

    admission = sub.add_parser("workspace-admit")
    admission.add_argument("--worktree", required=True)
    admission.add_argument("--worktree-root", required=True)
    # The five provisioning flags are OPTIONAL together (code-review finding 9,
    # admit-only backward compat): omitting all five preserves the prior
    # admit-only invocation shape; supplying all five provisions the exclusive
    # per-lane worktree. --starting-commit is the frozen contract flag name
    # (code-review finding 4; previously implemented as --head).
    admission.add_argument("--control-repo")
    admission.add_argument("--lane")
    admission.add_argument("--branch")
    admission.add_argument("--starting-commit")
    admission.add_argument("--repo-slug")
    admission.add_argument("--minimum-free-bytes", type=int, required=True)
    admission.add_argument("--conflict", action="append", default=[])
    admission.add_argument("--provider-overloaded", action="store_true")
    # Backfill an existing pre-fix hand-created worktree that carries no lane
    # record: verify its identity, derive its head, tolerate mid-delivery work,
    # and write only the out-of-tree record.
    admission.add_argument("--adopt-existing", action="store_true")
    # The octo-lite TOOLING repo (role_resolver.py, roles.toml, installer) that
    # becomes OCTO_CONTROL_REPO for role resolution. Optional; defaults to
    # --control-repo for a self-hosting lane. A TARGET lane sets it to the octo-lite
    # control repo so the loop resolves octo-lite tooling, not the target worktree.
    admission.add_argument("--octo-control-repo")
    admission.set_defaults(run=command_workspace_admit)

    cleanup = sub.add_parser("workspace-cleanup")
    cleanup.add_argument("--worktree", required=True)
    cleanup.add_argument("--worktree-root", required=True)
    cleanup.add_argument("--control-repo", required=True)
    cleanup.add_argument("--handoff", required=True)
    cleanup.add_argument("--expected-head", required=True)
    cleanup.add_argument("--remote-ref", required=True)
    cleanup.set_defaults(run=command_workspace_cleanup)

    shaping_journal = sub.add_parser("shaping-verdict-journal-write")
    shaping_journal.add_argument("--journal", required=True, help="output journal path Unit J consumes")
    shaping_journal.add_argument("--issue", required=True)
    shaping_journal.add_argument("--repo-slug", required=True, help="canonical owner/repo slug")
    shaping_journal.add_argument("--pr", type=int, required=True)
    shaping_journal.add_argument("--head", required=True, help="40-hex clear-verdict head")
    shaping_journal.add_argument(
        "--codex-session-id", required=True,
        help="shaping-reviewer relay codex session id whose rollout record backs the verdict",
    )
    shaping_journal.set_defaults(run=command_shaping_verdict_journal_write)
    return root


def main() -> int:
    try:
        args = parser().parse_args()
        print(json.dumps(args.run(args), sort_keys=True, ensure_ascii=False))
        return 0
    except (GateError, subprocess.CalledProcessError, json.JSONDecodeError, OSError) as error:
        print(f"octo-control: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
