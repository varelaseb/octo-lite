)

def load_toml(path: Path) -> dict:
    with path.open("rb") as handle:
        return tomllib.load(handle)


def run_json(argv: list[str]) -> dict:
    result = subprocess.run(argv, check=True, capture_output=True, text=True)
    return json.loads(result.stdout)


def linear_read(issue: str) -> dict:
    raw = run_json(["linear", "issue", "view", issue, "--json", "--no-download"])
    state = raw.get("state")
    normalized = dict(raw)
    normalized["state"] = state.get("name") if isinstance(state, dict) else state
    return {"issue": normalized, "fingerprint": exact_fingerprint(normalized)}


def _atomic_write_text(path: Path, text: str) -> None:
    temporary = path.with_suffix(path.suffix + f".{os.getpid()}.tmp")
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary.write_text(text)
    os.replace(temporary, path)


def write_status(path: Path, issue: dict, args) -> None:
    text = (
        f"Outcome: {args.outcome}\n"
        f"Gate: {args.gate}\n"
        f"Blocker: {args.blocker}\n"
        f"Next operator action: {args.next_action}\n"
        f"Issue: {issue['identifier']}\n"
        f"Linear state: {issue['state']}\n"
        f"Linear fingerprint: {exact_fingerprint(issue)}\n"
    )
    _atomic_write_text(path, text)


def command_linear_read(args) -> dict:
    return linear_read(args.issue)


def _verify_transition_authority(args) -> None:
    if bool(args.stream) == bool(args.receipt):
        raise GateError("exactly one of --stream or --receipt required")
    if args.stream:
        stream_state = load_toml(Path(args.stream) / "stream.toml")
        if stream_state.get("child_session") != args.caller:
            raise GateError("caller is not the exact stream owner")
        if stream_state.get("child_role") != "orchestrator":
            raise GateError("caller is not the exact issue-orchestrator role")
        if stream_state.get("stream_id") != args.issue:
            raise GateError("stream_id does not match requested issue")
        return
    receipt = load_toml(Path(args.receipt))
    # Defense in depth: recompute the launch revision (which excludes only ready
    # and [bootstrap], so a bootstrap-verified receipt still matches) so a receipt
    # whose [issue] or other bound field was edited after bootstrap without
    # recomputing the stored digest fails closed here. This is NOT the issue
    # authority boundary: launch_revision is an unkeyed self-digest a receipt
    # writer can recompute, so canonical exact-issue authority comes from the
    # host-owned stream registry via the --stream branch above, not this
    # file-based receipt self-assertion.
    if not isinstance(receipt.get("launch_revision"), str) or receipt["launch_revision"] != launch_revision(receipt):
        raise GateError("caller receipt launch revision mismatch")
    if receipt.get("bootstrap", {}).get("verified") is not True:
        raise GateError("caller receipt bootstrap not verified")
    if receipt.get("role", {}).get("name") != "orchestrator":
        raise GateError("caller is not the exact issue-orchestrator role")
    if receipt.get("issue", {}).get("identifier") != args.issue:
        raise GateError("caller receipt issue mismatch")
    if receipt.get("bootstrap", {}).get("provider_session_id") != args.caller:
        raise GateError("caller is not the exact receipt-bound session")


# Unit J shaped-transition authority (role-runtime launch-shaping-authority,
# launch-shaping-authority-issue, launch-receipt-persistent;
# delivery-lifecycle shaping-operator-approval-order; operating-model
# decision-109-binding): a Shaped transition binds to the verified generic
# persistent issue-orchestrator receipt whose launcher-resolved skill set
# includes shaping and whose stream dir claims this exact issue in the live
# streams/ registry, the journalled clear shaping verdict carrying
# relay-verbatim rollout-record provenance, and the Unit L operator-intent
# record stamping that same exact head. The retired worker shaping-review
# receipt and the interim published-verdict ack-echo path (tur-416 style)
# carry no authority.


def _read_shaping_verdict_journal(path: Path, issue: str) -> dict:
    if not path.is_file():
        raise GateError("journalled shaping verdict missing")
    try:
        entry = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError) as error:
        raise GateError("journalled shaping verdict unreadable") from error
    if not isinstance(entry, dict) or entry.get("schema_version") != 1:
        raise GateError("journalled shaping verdict schema mismatch")
    if entry.get("review_type") != "shaping":
        raise GateError("journalled shaping verdict wrong review type")
    if entry.get("verdict") != "clear":
        raise GateError("journalled shaping verdict not clear")
    if entry.get("issue") != issue:
        raise GateError("journalled shaping verdict issue mismatch")
    if not isinstance(entry.get("repo"), str) or not entry["repo"].strip():
        raise GateError("journalled shaping verdict repo missing")
    if not isinstance(entry.get("pr"), int):
        raise GateError("journalled shaping verdict pr missing")
    if not isinstance(entry.get("head"), str) or not re.fullmatch(r"[0-9a-f]{40}", entry["head"]):
        raise GateError("journalled shaping verdict head missing")
    # Workflow-native reviewer provenance of rollout-record grade (Unit C):
    # an unqualified verdict, including the interim published-verdict
    # ack-echo binding without these fields, carries no shaping authority.
    for key in ("codex_session_id", "verdict_sha256", "codex_model", "codex_effort", "verdict_payload"):
        if not isinstance(entry.get(key), str) or not entry[key].strip():
            raise GateError(f"journalled shaping verdict lacks rollout-record provenance: {key} missing")
    if entry.get("provenance") != "relay-verbatim-rollout":
        raise GateError(
            "journalled shaping verdict lacks rollout-record provenance: interim ack-echo authority retired"
        )
    # F5-r2 fix 2: the EXPECTED model/effort come from the CANONICAL roles.toml
    # shaping-reviewer role runtime via the role resolver, NOT from the journal's
    # self-reported codex_model/codex_effort. A forged journal that names its own
    # (weaker) model/effort and points at a matching rollout would otherwise
    # self-attest; verifying like-with-like against the canonical reviewer
    # runtime closes that. The journal's self-reported fields must ALSO equal the
    # canonical values (a divergent self-report signals a mis-provisioned or
    # tampered journal and is rejected before the rollout readback).
    expected_model, expected_effort = _canonical_shaping_reviewer_identity()
    if entry["codex_model"] != expected_model or entry["codex_effort"] != expected_effort:
        raise GateError(
            "journalled shaping verdict self-reported model/effort does not match the canonical "
            "roles.toml shaping-reviewer runtime"
        )
    # Rollout readback (role-runtime launch-shaping-authority, role-openai-fail-closed,
    # decision-identity-source): the declared provenance session id must resolve to
    # an ACTUAL codex rollout record under CODEX_HOME/sessions proving effective
    # provider=openai and the CANONICAL model/effort, and the verdict payload +
    # its sha256 must match that rollout's own final assistant message. An
    # arbitrary session id or hash with no resolvable rollout record, or a
    # non-OpenAI provider or wrong model/effort, is rejected fail-closed. The
    # self-reported codex_session_id/verdict_sha256 alone never suffice.
    try:
        verify_relay_verbatim(
            entry["codex_session_id"],
            entry["verdict_payload"],
            entry["verdict_sha256"],
            expected_model,
            expected_effort,
        )
    except GateError as error:
        raise GateError(
            f"journalled shaping verdict rollout readback failed: {error}"
        ) from error
    return entry


def _canonical_shaping_reviewer_identity() -> tuple[str, str]:
    # Derive the expected reviewer provider identity from the canonical
    # roles.toml shaping-reviewer runtime (decision-identity-source): the
    # readback verifies the rollout matches THIS canonical value, like-with-like,
    # so a journal cannot name its own model/effort and self-authorize.
    registry = load_registry(Path(__file__).resolve().parents[1])
    role = registry.roles.get("shaping-reviewer")
    if role is None:
        raise GateError("canonical roles.toml has no shaping-reviewer role")
    if role.provider != "openai":
        raise GateError("canonical shaping-reviewer provider is not openai")
    return role.model, role.effort


# D4 shaping-verdict journal PRODUCER (role-runtime launch-shaping-authority,
# role-openai-relay, role-openai-fail-closed; delivery-lifecycle
# shaping-operator-approval-order; operating-model decision-identity-source):
# the production writer that persists the journalled clear shaping verdict Unit
# J's _read_shaping_verdict_journal consumes. It does NOT trust caller-supplied
# payload/sha256/model/effort: it resolves the shaping-reviewer relay's exact
# codex session id to codex's OWN rollout record under CODEX_HOME/sessions
# (verify_relay_verbatim), proving effective provider=openai and the CANONICAL
# roles.toml shaping-reviewer model/effort, and takes the VERBATIM final
# assistant message and its sha256 from that record. The persisted journal
# therefore carries only rollout-record-grade provenance, and reading it back
# through the consumer proves the round-trip is authority-satisfying.
def command_shaping_verdict_journal_write(args) -> dict:
    path = Path(args.journal)
    head = args.head.strip()
    if not re.fullmatch(r"[0-9a-f]{40}", head):
        raise GateError("shaping verdict journal requires a 40-hex --head")
    if not isinstance(args.pr, int):
        raise GateError("shaping verdict journal requires --pr")
    repo_slug = _canonical_slug(args.repo_slug)
    if not isinstance(args.codex_session_id, str) or not args.codex_session_id.strip():
        raise GateError("shaping verdict journal requires --codex-session-id")
    session_id = args.codex_session_id.strip()
    # Canonical reviewer identity (never caller-supplied): the readback verifies
    # the rollout matches THIS canonical value, like-with-like.
    expected_model, expected_effort = _canonical_shaping_reviewer_identity()
    # Rollout readback: resolve the relay session id to codex's OWN rollout
    # record, prove provider=openai and the canonical model/effort, and take the
    # VERBATIM final assistant message from that record. Caller-supplied
    # payload/sha256 are never a source; an absent or wrong-identity rollout
    # fails closed here. The producer commits to exactly the record's own final
    # message and its digest, then re-verifies via verify_relay_verbatim so the
    # persisted payload/sha256 are the SAME the consumer independently reproves.
    payload = _rollout_final_message(session_id)
    verdict_sha256 = hashlib.sha256(payload.encode("utf-8")).hexdigest()
    record = verify_relay_verbatim(
        session_id, payload, verdict_sha256, expected_model, expected_effort,
    )
    # The persisted verdict must genuinely clear THIS exact issue, PR, and head,
    # exactly as Unit J's rollout-message binding requires; a rollout that
    # cleared a different issue, blocked, or named a different PR/head is
    # rejected before the journal is written, so a mis-provisioned pipeline
    # never persists an unusable journal.
    _verify_rollout_message_binds_verdict(payload, issue=args.issue, pr=args.pr, head=head)
    entry = {
        "schema_version": 1,
        "review_type": "shaping",
        "verdict": "clear",
        "issue": args.issue,
        "repo": repo_slug,
        "pr": args.pr,
        "head": head,
        "codex_session_id": args.codex_session_id.strip(),
        "verdict_payload": payload,
        "verdict_sha256": verdict_sha256,
        "codex_model": record["model"],
        "codex_effort": record["effort"],
        "provenance": "relay-verbatim-rollout",
    }
    _atomic_write_text(path, json.dumps(entry, sort_keys=True))
    # Consumer round-trip: read the persisted journal back through the exact
    # consumer Unit J uses, so a journal this producer writes is proven
    # authority-satisfying before success is reported.
    verified = _read_shaping_verdict_journal(path, args.issue)
    return {
        "journal": str(path.resolve()),
        "issue": verified["issue"],
        "repo": verified["repo"],
        "pr": verified["pr"],
        "head": verified["head"],
        "verdict": verified["verdict"],
        "codex_session_id": verified["codex_session_id"],
        "verdict_sha256": verified["verdict_sha256"],
        "codex_model": verified["codex_model"],
        "codex_effort": verified["codex_effort"],
        "provenance": verified["provenance"],
    }


def _rollout_final_message(session_id: str) -> str:
    # Resolve the verbatim final assistant message from codex's own rollout
    # record. This is the SAME record verify_relay_verbatim proves; reading it
    # first lets the producer commit to exactly that verbatim payload and its
    # digest rather than trusting any caller-supplied text.
    from octo_lite.launch import _read_codex_rollout_record  # noqa: E402

    record = _read_codex_rollout_record(session_id)
    message = record.get("final_message") or ""
    if not message:
        raise GateError("shaping verdict journal: rollout record has no final assistant message")
    return message


def _verify_shaped_transition_authority(args) -> dict:
    if args.stream or not args.receipt:
        raise GateError("Shaped transition requires exact persistent receipt authority")
    receipt_path = Path(args.receipt).resolve()
    receipt = load_toml(receipt_path)
    # The retired worker shaping-review receipt shape carries no authority.
    if receipt.get("purpose") == "shaping-review" and isinstance(receipt.get("shaping"), dict):
        raise GateError("retired worker shaping-review receipt carries no Shaped authority")
    if "purpose" in receipt:
        raise GateError("caller receipt carries a pass purpose; generic persistent shape required")
    if receipt.get("role", {}).get("name") != "orchestrator":
        raise GateError("caller is not the exact issue-orchestrator role")
    if receipt.get("bootstrap", {}).get("verified") is not True:
        raise GateError("caller receipt bootstrap not verified")
    if receipt.get("bootstrap", {}).get("provider_session_id") != args.caller:
        raise GateError("caller is not the exact receipt-bound session")
    if not isinstance(receipt.get("launch_revision"), str) or receipt["launch_revision"] != launch_revision(receipt):
        raise GateError("caller receipt launch revision mismatch")
    skills = receipt.get("skills")
    matched = skills.get("matched_capabilities") if isinstance(skills, dict) else None
    if not isinstance(matched, list) or "shaping" not in matched:
        raise GateError("caller receipt resolved skills lack shaping")
    # Exact-issue registry authority (launch-shaping-authority-issue): the
    # caller session must be this issue's registered issue orchestrator in
    # the live streams/ registry, so an epic orchestrator or an orchestrator
    # owning any other issue is rejected even with shaping capability.
    if receipt_path.name != "receipt.toml":
        raise GateError("caller receipt is not a stream registry receipt.toml")
    stream_dir = receipt_path.parent
    issue_table = receipt.get("issue")
    identity = issue_table.get("identifier") if isinstance(issue_table, dict) else None
    if not identity:
        raise GateError("epic orchestrator receipt binds no exact issue")
    if identity != args.issue:
        raise GateError("caller stream is registered to another issue")
    registry = stream_dir.parent
    for other_dir in sorted(path for path in registry.iterdir() if path.is_dir() and path != stream_dir):
        other_path = other_dir / "receipt.toml"
        if not other_path.is_file():
            continue
        try:
            other = load_toml(other_path)
        except (OSError, tomllib.TOMLDecodeError) as error:
            raise GateError(f"stream registry receipt unreadable: {other_path}") from error
        if other.get("bootstrap", {}).get("provider_session_id") != args.caller:
            continue
        other_issue_table = other.get("issue")
        other_identity = other_issue_table.get("identifier") if isinstance(other_issue_table, dict) else None
        if other_identity != args.issue:
            raise GateError("caller session is registered to another issue in the live stream registry")
    if not args.verdict_journal or not args.repo or not args.repo_slug:
        raise GateError("Shaped transition requires --verdict-journal, --repo, and --repo-slug")
    # Repo split: --repo is the LOCAL PATH used for git -C head checks; the
    # canonical owner/repo slug used for gh api / gh pr view is --repo-slug.
    # The single-value --repo dual-meaning is impossible (a filesystem path is
    # never a valid gh slug and vice versa), so the two are separate arguments
    # and the cross-surface binding compares one canonical slug identity.
    cli_slug = _canonical_slug(args.repo_slug)
    verdict = _read_shaping_verdict_journal(Path(args.verdict_journal), args.issue)
    # Repo-arg bind: a verdict binding a different canonical repo slug than the
    # CLI repo slug carries no authority here.
    if _canonical_slug(verdict["repo"]) != cli_slug:
        raise GateError("journalled verdict repo does not match CLI repo slug")
    # The Unit L operator-intent record, validated via the intent-record
    # --verify path (which re-reads the command-published PR/status surface and
    # checks the trusted-publisher comment author so a forged valid-head local
    # TOML is rejected), must stamp that same exact head and bind the same
    # canonical repo slug and PR the verdict does. The local path proves the
    # head commit exists; the slug is the surface identity.
    record = _verify_intent_record(
        stream_dir / "intent-record.toml", args.repo, cli_slug, args.trusted_publisher
    )
    # F5-r2 fix 3: bind the journalled verdict tuple (verdict=clear, issue, PR,
    # HEAD) to the actual rollout final message the verdict provenance resolves
    # to, so an unrelated / different-issue / blocking real rollout cannot back
    # an arbitrary clear Shaped transition for THIS issue and head. The verdict
    # journal already proved (in _read_shaping_verdict_journal) that its payload
    # equals the rollout record's own final assistant message; here that same
    # payload must COMMIT to this exact issue, PR, and clear-verdict HEAD.
    if record["head"] != verdict["head"]:
        raise GateError("operator-intent record head mismatch with journalled verdict")
    if record["pr"] != verdict["pr"]:
        raise GateError("operator-intent record pr mismatch with journalled verdict")
    _verify_rollout_message_binds_verdict(
        verdict["verdict_payload"], issue=args.issue, pr=verdict["pr"], head=verdict["head"]
    )
    return {"repo_slug": cli_slug, "pr": verdict["pr"], "head": verdict["head"]}


def _verify_rollout_message_binds_verdict(payload: str, *, issue: str, pr: int, head: str) -> None:
    # F5-r2 fix 3: the rollout final assistant message (proven verbatim equal to
    # the verdict payload in the rollout readback) must itself COMMIT to this
    # exact clear verdict on this exact issue, PR, and HEAD. Verbatim-payload
    # equality alone is insufficient: without this, a real rollout that cleared a
    # DIFFERENT issue, or blocked, or named a different PR/HEAD, could back an
    # arbitrary clear Shaped transition for this issue and head. The reviewer
    # rollout message must name the issue, the PR (`PR <n>` / `#<n>`), the exact
    # 40-hex HEAD, and a clear-verdict marker; a mis-provisioned pipeline that
    # pointed at an unrelated rollout is rejected fail-closed.
    #
    # D3 cycle2 (F5): the shaping-reviewer final message is PROSE (roles/
    # shaping-reviewer.md: "one exact-revision clear or blocking PR verdict
    # artifact"), not structured JSON, so this scans anchored lexically. But the
    # binding must be EXACT, not merely lexical:
    #   - issue: whole-token match, else `TUR-10` (or `TUR-4470`) backs `TUR-1`
    #     (or `TUR-447`) via substring, and `PR 60` backs `PR 6`.
    #   - verdict: a GENUINE clear assertion; a blocking message or negated clear
    #     (`not clear`, `cannot clear`, `unclear`, `blocking`) is rejected, since
    #     a bare `\bclear\b` matches "Not clear to proceed".
    text = payload if isinstance(payload, str) else ""
    missing: list[str] = []
    # Whole-token identifier: no alphanumeric or hyphen adjacent, so TUR-1 does
    # not match TUR-10 and TUR-447 does not match TUR-4470.
    if not re.search(
        rf"(?<![A-Za-z0-9-]){re.escape(issue)}(?![A-Za-z0-9-])", text
    ):
        missing.append("issue")
    # Exact PR token: the `PR `/`#` prefix anchors the front and the trailing
    # `(?![0-9])` anchors the back, so PR 6 does not match PR 60 or PR 16.
    if not re.search(rf"(?:PR\s*|#)0*{pr}(?![0-9])", text):
        missing.append("pr")
    if head not in text:
        missing.append("head")
    # Genuine clear verdict: an explicit clear assertion AND no blocking/negated
    # -clear marker. A blocking message that merely contains the word clear (e.g.
    # "Not clear to proceed") is rejected fail-closed.
    blocking = re.search(
        r"\b(?:blocking|blocked|unclear|not\s+clear|cannot\s+clear|can't\s+clear|"
        r"no[nt]-?\s*clear)\b",
        text,
        re.IGNORECASE,
    )
    genuine_clear = re.search(
        r"(?:^|(?<![A-Za-z]))(?:verdict\s*[:=]\s*clear|VERDICT\s+clear)"
        r"(?![A-Za-z])",
        text,
        re.IGNORECASE,
    )
    if blocking is not None or genuine_clear is None:
        missing.append("clear-verdict")
    if missing:
        raise GateError(
            "journalled verdict rollout message does not bind this issue/pr/head/clear verdict: "
            + ", ".join(missing)
        )


def _verify_fresh_shaping_head(repo: str, pr: object, expected_head: str) -> None:
    # A stale journalled verdict rejects here: the verdict head must equal
    # the freshly refetched live PR head immediately before mutation.
    current = run_json(["gh", "pr", "view", str(pr), "--repo", repo, "--json", "headRefOid"])
    if current.get("headRefOid") != expected_head:
        raise GateError("shaping PR head mismatch")


def command_linear_transition(args) -> dict:
    allowed = {
        ("Todo", "In Progress"),
        ("In Progress", "Awaiting Accept"),
        ("Ideas", "Shaped"),
        ("Todo", "Shaped"),
        # Loop fire: the one mechanical Shaped -> Todo delivery-entry transition
        # (delivery-lifecycle linear-loop-fire-transition, delivery-entry-gate).
        ("Shaped", "Todo"),
    }
    if (args.expected, args.target) not in allowed:
        raise GateError("stream orchestrator transition not allowed")
    if args.target == "Shaped":
        shaping = _verify_shaped_transition_authority(args)
    else:
        shaping = None
        _verify_transition_authority(args)

    def read():
        return linear_read(args.issue)["issue"]

    def mutate(target):
        if shaping is not None:
            _verify_fresh_shaping_head(shaping["repo_slug"], shaping["pr"], shaping["head"])
        subprocess.run(
            ["linear", "issue", "update", args.issue, "--state", target],
            check=True,
        )

    def status(issue):
        write_status(Path(args.status), dict(issue), args)

    def notify(issue):
        if not args.parent:
            raise GateError("parent route required")
        message = f"{args.issue} entered {issue['state']}; status {Path(args.status).resolve()}"
        if args.parent == "operator":
            # A top-level notification resolves the current owner through operator-say
            # rather than a static route, so it always reaches the post-handoff owner.
            subprocess.run(["operator-say", message], check=True)
        else:
            subprocess.run(["herdr-say", args.parent, message], check=True)

    return transition_linear(
        args.issue,
        args.expected,
        args.target,
        Path(args.progress),
        read,
        mutate,
        status,
        notify,
    )


def command_verdict(args) -> dict:
    # F5-r2 fix 4 (the --repo dual-use bug): --repo is the LOCAL git path,
    # --repo-slug is the canonical owner/repo gh identity used for gh pr view /
    # gh api, exactly like linear-transition. A filesystem path is never a valid
    # gh slug, so the two are separate arguments and a local path can no longer
    # leak into gh calls.
    slug = _canonical_slug(args.repo_slug)
    current = run_json(
        ["gh", "pr", "view", str(args.pr), "--repo", slug, "--json", "headRefOid"]
    )["headRefOid"]
    if current != args.head:
        raise GateError("PR HEAD mismatch")
    body = verdict_body(
        args.review_type,
        args.verdict,
        args.head,
        args.bound_input,
        args.finding,
        args.receipt,
        args.conversation_log_reference,
        args.conversation_cutoff,
    )
    marker = f"<!-- octo-lite-verdict:{args.review_type} -->"
    comments = run_json(
        ["gh", "api", f"repos/{slug}/issues/{args.pr}/comments", "--paginate"]
    )
    existing = next((item for item in comments if marker in item.get("body", "")), None)
    if existing:
        published = run_json(
            [
                "gh", "api", "--method", "PATCH",
                f"repos/{slug}/issues/comments/{existing['id']}",
                "-f", f"body={body}",
            ]
        )
    else:
        published = run_json(
            [
                "gh", "api", "--method", "POST",
                f"repos/{slug}/issues/{args.pr}/comments",
                "-f", f"body={body}",
            ]
        )
    readback = run_json(
        ["gh", "api", f"repos/{slug}/issues/comments/{published['id']}"]
    )
    if readback.get("body") != body:
        raise GateError("verdict comment readback mismatch")
    return {"url": readback["html_url"], "head": args.head, "verdict": args.verdict}


def command_owner(args) -> dict:
    handoff = Path(args.handoff)
    if not handoff.is_file():
        raise GateError("immutable handoff missing")
    return transfer_owner(
        Path(args.owner_file),
        args.expected_owner,
        args.expected_route,
        args.expected_revision,
        args.new_owner,
        args.new_route,
        args.revision,
        str(Path(args.control_dir).resolve()),
        caller=args.caller,
        handoff=handoff,
        successor_readiness_path=Path(args.successor_readiness),
    )


def command_successor_ready(args) -> dict:
    return declare_successor_ready(
        Path(args.path), caller=args.caller, session_id=args.session_id, handoff_revision=args.handoff_revision,
    )


def command_accept(args) -> dict:
